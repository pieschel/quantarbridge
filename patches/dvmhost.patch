+        return;
+    }
+    g_motorolaPacketNsByDirection[motorolaDirectionKey(sourceRid, targetRid)] = static_cast<uint8_t>(ns & 0x07U);
+}
+
+uint8_t nextMotorolaPacketNs(uint32_t sourceRid, uint32_t targetRid, uint8_t fallback)
+{
+    if (sourceRid == 0U || targetRid == 0U || targetRid == 16777215U) {
+        return static_cast<uint8_t>(fallback & 0x07U);
+    }
+
+    const auto it = g_motorolaPacketNsByDirection.find(motorolaDirectionKey(sourceRid, targetRid));
+    if (it == g_motorolaPacketNsByDirection.end()) {
+        return static_cast<uint8_t>(fallback & 0x07U);
+    }
+
+    return static_cast<uint8_t>((it->second + 1U) & 0x07U);
+}
