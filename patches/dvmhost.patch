+bool readMotorolaVlq(const uint8_t* data, uint32_t length, uint32_t offset,
+    uint32_t& value, uint32_t& bytesRead)
+{
+    value = 0U;
+    bytesRead = 0U;
+    for (uint32_t i = 0U; i < 5U && offset + i < length; ++i) {
+        const uint8_t byte = data[offset + i];
+        if (value > 0x01FFFFFFU) {
+            return false;
+        }
+        value = static_cast<uint32_t>((value << 7U) | (byte & 0x7FU));
+        bytesRead++;
+        if ((byte & 0x80U) == 0U) {
+            return true;
+        }
+    }
+    return false;
+}
+
+bool parseMotorolaLocationReport(const uint8_t* data, uint32_t length,
+    uint32_t subscriberIp, uint8_t& reportType, uint16_t& sourcePort,
+    bool& hasPosition, uint32_t& resultCode)
+{
+    hasPosition = false;
+    resultCode = kMotorolaLrrpResultUnknown;
+    if (data == nullptr || length < 30U || (data[0U] >> 4U) != 4U ||
+        data[9U] != 0x11U) {
+        return false;
+    }
+
+    const uint32_t ipHeaderLength = static_cast<uint32_t>(data[0U] & 0x0FU) * 4U;
+    const uint32_t packetLength = readUint16BE(data + 2U);
+    if (ipHeaderLength < 20U || packetLength > length ||
+        packetLength < ipHeaderLength + 10U ||
+        readUint32BE(data + 12U) != subscriberIp ||
+        readUint32BE(data + 16U) != g_motorolaArsServerIp ||
+        checksum16(data, ipHeaderLength) != 0U) {
+        return false;
+    }
+
+    const uint8_t* udp = data + ipHeaderLength;
+    sourcePort = readUint16BE(udp);
+    const uint16_t targetPort = readUint16BE(udp + 2U);
+    const uint32_t udpLength = readUint16BE(udp + 4U);
+    const bool locationPorts =
+        (sourcePort == kMotorolaP25LocationPort && targetPort == kMotorolaP25LocationPort) ||
+        (sourcePort == kMotorolaLegacyLocationPort && targetPort == kMotorolaLegacyLocationPort);
+    if (!locationPorts || udpLength < 10U ||
+        ipHeaderLength + udpLength > packetLength) {
+        return false;
+    }
+
+    const uint8_t* payload = udp + 8U;
+    const uint32_t payloadLength = udpLength - 8U;
+    reportType = static_cast<uint8_t>(payload[0U] & 0x7FU);
+    if ((reportType != 0x07U && reportType != 0x0DU) ||
+        payload[1U] + 2U > payloadLength) {
+        return false;
+    }
+
+    if (readUint16BE(udp + 6U) != 0U) {
+        std::vector<uint8_t> pseudo;
+        pseudo.reserve(12U + udpLength);
+        pseudo.insert(pseudo.end(), data + 12U, data + 20U);
+        pseudo.push_back(0x00U);
+        pseudo.push_back(0x11U);
+        pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+        pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+        pseudo.insert(pseudo.end(), udp, udp + udpLength);
+        if (checksum16(pseudo.data(), pseudo.size()) != 0U) {
+            return false;
+        }
+    }
+
+    const uint32_t reportLength = static_cast<uint32_t>(payload[1U]) + 2U;
+    uint32_t offset = 2U;
+    if (offset + 2U <= reportLength && payload[offset] == 0x22U) {
+        const uint32_t requestIdLength = payload[offset + 1U];
+        if (offset + 2U + requestIdLength > reportLength) {
+            return false;
+        }
+        offset += 2U + requestIdLength;
+    }
+
+    while (offset < reportLength) {
+        switch (payload[offset]) {
+        case 0x34U: // Date/time token plus five encoded bytes.
+            if (offset + 6U > reportLength) {
+                return false;
+            }
+            offset += 6U;
+            break;
+        case 0x37U: { // Result code encoded as a Motorola VLQ.
+            uint32_t bytesRead = 0U;
+            if (!readMotorolaVlq(payload, reportLength, offset + 1U,
+                    resultCode, bytesRead)) {
+                return false;
+            }
+            offset += 1U + bytesRead;
+            break;
+        }
+        case 0x51U: // Circle
+        case 0x55U: // Sphere
+        case 0x66U: // Point
+        case 0x69U: // Point with altitude
+            if (offset + 9U > reportLength) {
+                return false;
+            }
+            hasPosition = true;
+            return true;
+        case 0x56U: // Horizontal direction
+            if (offset + 2U > reportLength) {
+                return false;
+            }
+            offset += 2U;
+            break;
+        default:
+            // The LRRP envelope is valid, but this implementation does not
+            // treat an unknown token as a usable APRS position.
+            return true;
+        }
+    }
+    return true;
+}
+
+std::vector<uint8_t> buildMotorolaTmsInboundMessage(uint32_t subscriberIp,
+    uint8_t messageId, const std::string& address, const std::string& text)
+{
+    std::vector<uint8_t> tmsPayload(4U, 0x00U);
+    tmsPayload[2U] = 0xE0U;
+    const size_t addressChars = std::min<size_t>(address.size(), 0x7FU);
+    tmsPayload[3U] = static_cast<uint8_t>(addressChars * 2U);
+    for (size_t i = 0U; i < addressChars; ++i) {
+        tmsPayload.push_back(static_cast<uint8_t>(address[i]));
+        tmsPayload.push_back(0x00U);
+    }
+    tmsPayload.push_back(static_cast<uint8_t>(0x80U | (messageId & 0x1FU)));
+    tmsPayload.push_back(0x04U);
+    for (const unsigned char ch : text) {
+        tmsPayload.push_back(ch);
+        tmsPayload.push_back(0x00U);
+    }
+    writeUint16BE(tmsPayload, 0U,
+        static_cast<uint16_t>(tmsPayload.size() - 2U));
+
+    const uint16_t udpLength = static_cast<uint16_t>(8U + tmsPayload.size());
+    const uint16_t packetLength = static_cast<uint16_t>(20U + udpLength);
+    std::vector<uint8_t> response(packetLength, 0x00U);
+    response[0U] = 0x45U;
+    writeUint16BE(response, 2U, packetLength);
+    writeUint16BE(response, 4U, 0x5179U);
+    response[8U] = 0x40U;
+    response[9U] = 0x11U;
+    writeUint32BE(response, 12U, g_motorolaArsServerIp);
+    writeUint32BE(response, 16U, subscriberIp);
+    writeUint16BE(response, 20U, kMotorolaTmsPort);
+    writeUint16BE(response, 22U, kMotorolaTmsPort);
+    writeUint16BE(response, 24U, udpLength);
+    std::copy(tmsPayload.begin(), tmsPayload.end(), response.begin() + 28U);
+    writeUint16BE(response, 10U, checksum16(response.data(), 20U));
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), response.begin() + 12U, response.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+    pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), response.begin() + 20U, response.end());
+    uint16_t udpChecksum = checksum16(pseudo.data(), pseudo.size());
+    if (udpChecksum == 0U) {
+        udpChecksum = 0xFFFFU;
+    }
+    writeUint16BE(response, 26U, udpChecksum);
+    return response;
+}
+
+bool isMotorolaTmsServiceAcknowledgement(const uint8_t* data, uint32_t length,
+    uint32_t subscriberIp)
+{
+    if (data == nullptr || length != 32U || data[0U] != 0x45U ||
+        readUint16BE(data + 2U) != length || data[9U] != 0x11U ||
+        readUint32BE(data + 12U) != subscriberIp ||
+        readUint32BE(data + 16U) != g_motorolaArsServerIp ||
+        readUint16BE(data + 20U) != kMotorolaTmsPort ||
+        readUint16BE(data + 22U) != kMotorolaTmsPort ||
+        readUint16BE(data + 24U) != 12U || checksum16(data, 20U) != 0U) {
+        return false;
+    }
+
+    if (data[28U] != 0x00U || data[29U] != 0x02U ||
+        (data[30U] & 0x1FU) != 0x1FU || data[31U] != 0x00U) {
+        return false;
+    }
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(24U);
+    pseudo.insert(pseudo.end(), data + 12U, data + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x0CU);
+    pseudo.insert(pseudo.end(), data + 20U, data + length);
+    return readUint16BE(data + 26U) == 0U || checksum16(pseudo.data(), pseudo.size()) == 0U;
+}
+
+bool isMotorolaTmsMessageAcknowledgement(const uint8_t* data, uint32_t length,
+    uint32_t subscriberIp, uint8_t& messageId)
+{
+    if (data == nullptr || length != 33U || data[0U] != 0x45U ||
+        readUint16BE(data + 2U) != length || data[9U] != 0x11U ||
+        readUint32BE(data + 12U) != subscriberIp ||
+        readUint32BE(data + 16U) != g_motorolaArsServerIp ||
+        readUint16BE(data + 20U) != kMotorolaTmsPort ||
+        readUint16BE(data + 22U) != kMotorolaTmsPort ||
+        readUint16BE(data + 24U) != 13U || checksum16(data, 20U) != 0U ||
+        data[28U] != 0x00U || data[29U] != 0x03U ||
+        (data[30U] & 0x1FU) != 0x1FU || data[31U] != 0x00U) {
+        return false;
+    }
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(25U);
+    pseudo.insert(pseudo.end(), data + 12U, data + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x0DU);
+    pseudo.insert(pseudo.end(), data + 20U, data + length);
+    if (readUint16BE(data + 26U) != 0U && checksum16(pseudo.data(), pseudo.size()) != 0U) {
+        return false;
+    }
+
+    messageId = data[32U] & 0x1FU;
+    return true;
+}
+
+struct MotorolaTmsMessage {
+    uint32_t targetRid {0U};
+    uint32_t sourceIp {0U};
+    uint32_t targetIp {0U};
+    uint8_t operation {0U};
+    uint8_t messageId {0U};
+    std::string address;
+    std::string text;
+};
+
+void appendUtf8(std::string& output, uint16_t codePoint)
+{
+    if (codePoint <= 0x7FU) {
+        output.push_back(static_cast<char>(codePoint));
+    } else if (codePoint <= 0x7FFU) {
+        output.push_back(static_cast<char>(0xC0U | (codePoint >> 6U)));
+        output.push_back(static_cast<char>(0x80U | (codePoint & 0x3FU)));
+    } else {
+        output.push_back(static_cast<char>(0xE0U | (codePoint >> 12U)));
+        output.push_back(static_cast<char>(0x80U | ((codePoint >> 6U) & 0x3FU)));
+        output.push_back(static_cast<char>(0x80U | (codePoint & 0x3FU)));
+    }
+}
+
+bool parseMotorolaTmsMessagePacket(const uint8_t* data, uint32_t length,
+    uint32_t subscriberIp, MotorolaTmsMessage& message)
+{
+    if (data == nullptr || length < 34U || data[0U] != 0x45U ||
+        readUint16BE(data + 2U) > length || data[9U] != 0x11U ||
+        readUint32BE(data + 12U) != subscriberIp ||
+        readUint16BE(data + 20U) != kMotorolaTmsPort ||
+        readUint16BE(data + 22U) != kMotorolaTmsPort || checksum16(data, 20U) != 0U) {
+        return false;
+    }
+
+    message.sourceIp = readUint32BE(data + 12U);
+    message.targetIp = readUint32BE(data + 16U);
+
+    const uint16_t udpLength = readUint16BE(data + 24U);
+    if (udpLength < 14U || 20U + udpLength > length) {
+        return false;
+    }
+    const uint8_t* payload = data + 28U;
+    const uint32_t payloadLength = udpLength - 8U;
+    uint32_t messageEnd = payloadLength;
+    const uint16_t declaredLength = readUint16BE(payload);
+    if (declaredLength >= 4U && declaredLength + 2U <= payloadLength) {
+        messageEnd = declaredLength + 2U;
+    }
+
+    uint32_t operationOffset = 2U;
+    auto isSimpleTextOperation = [](uint8_t operation) {
+        return (operation & 0x80U) != 0U && (operation & 0x1FU) == 0U;
+    };
+    if (operationOffset >= messageEnd ||
+        !isSimpleTextOperation(payload[operationOffset])) {
+        operationOffset = messageEnd;
+        const uint32_t scanEnd = std::min<uint32_t>(messageEnd, 12U);
+        for (uint32_t i = 0U; i + 1U < scanEnd; ++i) {
+            if (isSimpleTextOperation(payload[i])) {
+                operationOffset = i;
+                break;
+            }
+        }
+    }
+    if (operationOffset + 2U > messageEnd) {
+        return false;
+    }
+
+    message.operation = payload[operationOffset];
+    const uint32_t addressLength = payload[operationOffset + 1U];
+    const uint32_t addressOffset = operationOffset + 2U;
+    uint32_t offset = addressOffset + addressLength;
+    if (offset > messageEnd) {
+        return false;
+    }
+
+    bool utf16Address = addressLength >= 2U && (addressLength % 2U) == 0U;
+    if (utf16Address) {
+        for (uint32_t i = 1U; i < addressLength; i += 2U) {
+            if (payload[addressOffset + i] != 0x00U) {
+                utf16Address = false;
+                break;
+            }
+        }
+    }
+    if (utf16Address) {
+        for (uint32_t i = 0U; i < addressLength; i += 2U) {
+            if (payload[addressOffset + i] != 0x00U) {
+                message.address.push_back(static_cast<char>(payload[addressOffset + i]));
+            }
+        }
+    } else {
+        message.address.assign(reinterpret_cast<const char*>(payload + addressOffset),
+            addressLength);
+    }
+    if (!message.address.empty() &&
+        message.address.find_first_not_of("0123456789") == std::string::npos) {
+        try {
+            message.targetRid = static_cast<uint32_t>(std::stoul(message.address));
+        } catch (...) {
+            message.targetRid = 0U;
+        }
+    }
+
+    uint32_t encodingOffset = messageEnd;
+    for (uint32_t i = offset; i + 1U < messageEnd; ++i) {
+        if ((payload[i] & 0x80U) != 0U &&
+            (payload[i + 1U] & 0x1FU) == 0x04U) {
+            encodingOffset = i;
+            break;
+        }
+    }
+    if (encodingOffset == messageEnd) {
+        return false;
+    }
+    message.messageId = payload[encodingOffset] & 0x1FU;
+    offset = encodingOffset + 2U;
+
+    if (offset + 3U < messageEnd && payload[offset] == 0x0DU &&
+        payload[offset + 1U] == 0x00U && payload[offset + 2U] == 0x0AU &&
+        payload[offset + 3U] == 0x00U) {
+        offset += 4U;
+    }
+
+    while (offset + 1U < messageEnd) {
+        const uint16_t codePoint = static_cast<uint16_t>(payload[offset]) |
+            (static_cast<uint16_t>(payload[offset + 1U]) << 8U);
+        offset += 2U;
+        if (codePoint == 0U) {
+            break;
+        }
+        appendUtf8(message.text, codePoint);
+    }
+    return !message.text.empty();
+}
+
+std::vector<uint8_t> buildMotorolaTmsMessageAcknowledgement(uint32_t sourceIp,
+    uint32_t targetIp, uint8_t requestOperation, uint8_t messageId)
+{
+    const uint8_t acknowledgementOperation = static_cast<uint8_t>(
+        0x9FU | (requestOperation & 0x20U));
+    const uint8_t tmsPayload[] = {
+        0x00U, 0x03U, acknowledgementOperation, 0x00U,
+        static_cast<uint8_t>(messageId & 0x1FU)
+    };
+    const uint16_t udpLength = static_cast<uint16_t>(8U + sizeof(tmsPayload));
+    const uint16_t packetLength = static_cast<uint16_t>(20U + udpLength);
+
+    std::vector<uint8_t> response(packetLength, 0x00U);
+    response[0U] = 0x45U;
+    writeUint16BE(response, 2U, packetLength);
+    writeUint16BE(response, 4U, 0x5178U);
+    response[8U] = 0x40U;
+    response[9U] = 0x11U;
+    writeUint32BE(response, 12U, sourceIp);
+    writeUint32BE(response, 16U, targetIp);
+    writeUint16BE(response, 20U, kMotorolaTmsPort);
+    writeUint16BE(response, 22U, kMotorolaTmsPort);
+    writeUint16BE(response, 24U, udpLength);
+    std::copy(tmsPayload, tmsPayload + sizeof(tmsPayload), response.begin() + 28U);
+    writeUint16BE(response, 10U, checksum16(response.data(), 20U));
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), response.begin() + 12U, response.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+    pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), response.begin() + 20U, response.end());
+    writeUint16BE(response, 26U, checksum16(pseudo.data(), pseudo.size()));
+    return response;
+}
+
+uint16_t updateChecksum16(uint16_t checksum, const std::vector<uint8_t>& from, const std::vector<uint8_t>& to)
+{
+    if (from.size() != to.size()) {
+        return checksum;
+    }
+
+    uint32_t sum = static_cast<uint16_t>(~checksum);
+    for (size_t i = 0U; i < from.size(); i += 2U) {
+        const uint16_t oldWord = (static_cast<uint16_t>(from[i]) << 8U) |
+            (i + 1U < from.size() ? from[i + 1U] : 0x00U);
+        const uint16_t newWord = (static_cast<uint16_t>(to[i]) << 8U) |
+            (i + 1U < to.size() ? to[i + 1U] : 0x00U);
+        sum += static_cast<uint16_t>(~oldWord);
+        sum += newWord;
+        while ((sum >> 16U) != 0U) {
+            sum = (sum & 0xFFFFU) + (sum >> 16U);
+        }
+    }
+
+    return static_cast<uint16_t>(~sum);
+}
+
+uint16_t motorolaPeerChecksumForRidText(const std::string& ridText)
+{
+    const bool sixDigitRid = ridText.size() == 6U;
+    const std::string templateText = sixDigitRid ? "100002" : "1000002";
+    const uint16_t templateChecksum = sixDigitRid ? 0x2837U : 0xB376U;
+    return updateChecksum16(templateChecksum,
+        std::vector<uint8_t>(templateText.begin(), templateText.end()),
+        std::vector<uint8_t>(ridText.begin(), ridText.end()));
+}
+
+UInt8Array assembleConfirmedPduWithRawUserData(data::DataHeader& dataHeader, const std::vector<uint8_t>& pduUserData,
+    uint32_t* assembledBitLength)
+{
+    if (assembledBitLength != nullptr)
+        *assembledBitLength = 0U;
+
+    const uint32_t blocksToFollow = dataHeader.getBlocksToFollow();
+    uint32_t bitLength = ((blocksToFollow + 1U) * P25_PDU_FEC_LENGTH_BITS) + P25_PREAMBLE_LENGTH_BITS;
+    UInt8Array dataArray = std::make_unique<uint8_t[]>((bitLength / 8U) + 1U);
+    uint8_t* data = dataArray.get();
+    ::memset(data, 0x00U, (bitLength / 8U) + 1U);
+
+    uint8_t block[P25_PDU_FEC_LENGTH_BYTES];
+    ::memset(block, 0x00U, P25_PDU_FEC_LENGTH_BYTES);
+
+    uint32_t offset = P25_PREAMBLE_LENGTH_BITS;
+    dataHeader.encode(block);
+    Utils::setBitRange(block, data, offset, P25_PDU_FEC_LENGTH_BITS);
+    offset += P25_PDU_FEC_LENGTH_BITS;
+
+    uint32_t dataOffset = 0U;
+    for (uint32_t i = 0U; i < blocksToFollow; ++i) {
+        data::DataBlock dataBlock = data::DataBlock();
+        dataBlock.setFormat(dataHeader);
+        dataBlock.setSerialNo(static_cast<uint8_t>(i));
+        dataBlock.setData(pduUserData.data() + dataOffset);
+        dataBlock.setLastBlock((i + 1U) == blocksToFollow);
+
+        ::memset(block, 0x00U, P25_PDU_FEC_LENGTH_BYTES);
+        dataBlock.encode(block);
+        Utils::setBitRange(block, data, offset, P25_PDU_FEC_LENGTH_BITS);
+
+        offset += P25_PDU_FEC_LENGTH_BITS;
+        dataOffset += P25_PDU_CONFIRMED_DATA_LENGTH_BYTES;
+    }
+
+    if (assembledBitLength != nullptr)
+        *assembledBitLength = bitLength;
+
+    return dataArray;
+}
+
+bool parseMotorolaArs(const uint8_t* data, uint32_t length, uint32_t& sourceRid, uint32_t& targetRid)
+{
+    if (data == nullptr || length < 34U) return false;
+    if (!(data[0U] == 0x45U && data[9U] == 0x11U)) return false;
+    const uint16_t srcPort = (static_cast<uint16_t>(data[20U]) << 8) | data[21U];
+    const uint16_t dstPort = (static_cast<uint16_t>(data[22U]) << 8) | data[23U];
+    if (srcPort != 4005U || dstPort != 4005U) return false;
+    const uint8_t* udpPayload = data + 28U;
+    const uint32_t udpPayloadLength = length - 28U;
+    if (udpPayloadLength < 6U) return false;
+    if (!(udpPayload[0U] == 0x00U && udpPayload[2U] == 0x72U)) return false;
+    if (udpPayloadLength >= 2U && udpPayload[1U] != static_cast<uint8_t>(udpPayloadLength - 2U)) return false;
+
+    const uint32_t sourceLen = udpPayload[3U];
+    if (sourceLen == 0U || sourceLen > 10U || 4U + sourceLen >= udpPayloadLength) return false;
+    const uint32_t targetLenOffset = 4U + sourceLen;
+    const uint32_t targetLen = udpPayload[targetLenOffset];
+    if (targetLen == 0U || targetLen > 10U || targetLenOffset + 1U + targetLen > udpPayloadLength) return false;
+
+    std::string src(reinterpret_cast<const char*>(udpPayload + 4U), sourceLen);
+    std::string dst(reinterpret_cast<const char*>(udpPayload + targetLenOffset + 1U), targetLen);
+    if (src.find_first_not_of("0123456789") != std::string::npos || dst.find_first_not_of("0123456789") != std::string::npos) return false;
+    try {
+        sourceRid = static_cast<uint32_t>(std::stoul(src));
+        targetRid = static_cast<uint32_t>(std::stoul(dst));
+    } catch (...) {
+        return false;
+    }
+    return true;
+}
+
+bool parseMotorolaArsRefresh(const uint8_t* data, uint32_t length, uint32_t sourceRid,
+    uint32_t& subscriberIp, uint16_t& requestIpId)
+{
+    if (data == nullptr || length < 42U || sourceRid == 0U || sourceRid > 9999999U) {
+        return false;
+    }
+    const uint16_t packetLength = readUint16BE(data + 2U);
+    const uint16_t udpLength = readUint16BE(data + 24U);
+    if (packetLength != length || (udpLength != 22U && udpLength != 29U) ||
+        packetLength != 20U + udpLength || data[0U] != 0x45U || data[9U] != 0x11U ||
+        readUint32BE(data + 16U) != g_motorolaArsServerIp ||
+        readUint16BE(data + 20U) != kMotorolaArsPort || readUint16BE(data + 22U) != kMotorolaArsPort ||
+        checksum16(data, 20U) != 0U) {
+        return false;
+    }
+
+    const uint8_t* payload = data + 28U;
+    const uint16_t payloadLength = udpLength - 8U;
+    const std::string ridText = std::to_string(sourceRid);
+    const bool compactIdentity = payloadLength == 14U && payload[12U] == 0x00U && payload[13U] == 0x00U;
+    const bool dualIdentity = payloadLength == 21U && payload[12U] == 0x07U &&
+        std::equal(ridText.begin(), ridText.end(), payload + 13U) && payload[20U] == 0x00U;
+    if (ridText.size() != 7U || readUint16BE(payload) != payloadLength - 2U ||
+        payload[2U] != 0xF0U || (payload[3U] != 0x20U && payload[3U] != 0x40U) ||
+        payload[4U] != 0x07U || !std::equal(ridText.begin(), ridText.end(), payload + 5U) ||
+        (!compactIdentity && !dualIdentity)) {
+        return false;
+    }
+
+    std::vector<uint8_t> pseudo; pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), data + 12U, data + 20U);
+    pseudo.push_back(0x00U); pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU)); pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), data + 20U, data + packetLength);
+    if (readUint16BE(data + 26U) != 0U && checksum16(pseudo.data(), pseudo.size()) != 0U) return false;
+    subscriberIp = readUint32BE(data + 12U); requestIpId = readUint16BE(data + 4U);
+    return subscriberIp != 0U && subscriberIp != 0xFFFFFFFFU;
+}
+
+std::string extractTmsFragment(const uint8_t* data, uint32_t length)
+{
+    if (data == nullptr || length < 4U) return {};
+    for (uint32_t i = 0U; i + 2U < length; ++i) {
+        if ((data[i] & 0xE0U) == 0x80U && data[i + 1U] == 0x04U) {
+            std::string out;
+            for (uint32_t j = i + 2U; j < length; ) {
+                if (j + 2U < length && data[j] == 0x00U &&
+                    data[j + 1U] >= 0x20U && data[j + 1U] <= 0x7EU &&
+                    data[j + 2U] == 0x00U) {
+                    ++j;
+                    continue;
+                }
+                if (j + 1U < length && data[j + 1U] == 0x00U && data[j] >= 0x20U && data[j] <= 0x7EU) {
+                    out.push_back(static_cast<char>(data[j]));
+                    j += 2U;
+                    continue;
+                }
+                if (data[j] >= 0x20U && data[j] <= 0x7EU) {
+                    out.push_back(static_cast<char>(data[j]));
+                    ++j;
+                    continue;
+                }
+                break;
+            }
+            if (!out.empty()) return out;
+        }
+    }
+    return {};
+}
+
+bool parseMotorolaTms(const uint8_t* data, uint32_t length, uint32_t& sourceRid, std::string& text)
+{
+    if (data == nullptr || length < 31U) return false;
+    if (!(data[0U] == 0x45U && data[9U] == 0x11U)) return false;
+
+    uint32_t udpPayloadOffset = 0U;
+    for (uint32_t i = 20U; i + 8U <= length && i <= 24U; ++i) {
+        const uint16_t srcPort = (static_cast<uint16_t>(data[i]) << 8) | data[i + 1U];
+        const uint16_t dstPort = (static_cast<uint16_t>(data[i + 2U]) << 8) | data[i + 3U];
+        if (srcPort == 4007U && (dstPort == 4007U || dstPort == 3840U)) {
+            udpPayloadOffset = i + 8U;
+            break;
+        }
+    }
+    if (udpPayloadOffset == 0U) return false;
+
+    const uint8_t* udpPayload = data + udpPayloadOffset;
+    const uint32_t udpLen = length - udpPayloadOffset;
+    text = extractTmsFragment(udpPayload, udpLen);
+    if (text.empty()) return false;
+    sourceRid = 0U;
+    std::string digits;
+    for (uint32_t i = 0U; i + 1U < udpLen; ++i) {
+        if (udpPayload[i + 1U] == 0x00U && udpPayload[i] >= '0' && udpPayload[i] <= '9') digits.push_back(static_cast<char>(udpPayload[i]));
+    }
+    // APX peer TMS frames can expose only a partial RID before the text marker;
+    // callers fall back to the P25 header source when this stays zero.
+    if (digits.size() >= 7U) {
+        sourceRid = static_cast<uint32_t>(std::stoul(digits.substr(0U, 7U)));
+    }
+    return true;
+}
+
+std::string bytesToHexString(const uint8_t* data, uint32_t length);
+
+bool isMotorolaTmsIpPacket(const uint8_t* data, uint32_t length)
+{
+    if (data == nullptr || length < 28U) return false;
+    if (!(data[0U] == 0x45U && data[9U] == 0x11U)) return false;
+
+    for (uint32_t i = 20U; i + 8U <= length && i <= 24U; ++i) {
+        const uint16_t srcPort = (static_cast<uint16_t>(data[i]) << 8U) | data[i + 1U];
+        const uint16_t dstPort = (static_cast<uint16_t>(data[i + 2U]) << 8U) | data[i + 3U];
+        if (srcPort == 4007U && (dstPort == 4007U || dstPort == 3840U)) {
+            return true;
+        }
+    }
+
+    return false;
+}
+
+bool isMotorolaTmsDeliveryStatusIpPacket(const uint8_t* data, uint32_t length)
+{
+    if (data == nullptr || length < 33U) return false;
+    if (!(data[0U] == 0x45U && data[9U] == 0x11U)) return false;
+
+    for (uint32_t i = 20U; i + 8U <= length && i <= 24U; ++i) {
+        const uint16_t srcPort = (static_cast<uint16_t>(data[i]) << 8U) | data[i + 1U];
+        const uint16_t dstPort = (static_cast<uint16_t>(data[i + 2U]) << 8U) | data[i + 3U];
+        if (srcPort == 4007U && dstPort == 4007U) {
+            const uint32_t udpPayloadOffset = i + 8U;
+            return udpPayloadOffset + 5U <= length &&
+                data[udpPayloadOffset] == 0x82U &&
+                data[udpPayloadOffset + 2U] == 0x04U &&
+                data[udpPayloadOffset + 4U] == 0x3FU;
+        }
+    }
+
+    return false;
+}
+
+bool isMotorolaPeerControlIpPacket(const uint8_t* data, uint32_t length)
+{
+    if (data == nullptr || length < 32U) return false;
+    if (!(data[0U] == 0x45U && data[9U] == 0x11U)) return false;
+
+    for (uint32_t i = 20U; i + 12U <= length && i <= 24U; ++i) {
+        const uint16_t srcPort = (static_cast<uint16_t>(data[i]) << 8U) | data[i + 1U];
+        const uint16_t dstPort = (static_cast<uint16_t>(data[i + 2U]) << 8U) | data[i + 3U];
+        if (srcPort != 4005U || dstPort != 4005U) {
+            continue;
+        }
+
+        const uint32_t udpPayloadOffset = i + 8U;
+        return udpPayloadOffset + 4U <= length &&
+            data[udpPayloadOffset] == 0x00U &&
+            data[udpPayloadOffset + 2U] == 0x00U &&
+            data[udpPayloadOffset + 3U] == 0x3FU;
+    }
+
+    return false;
+}
