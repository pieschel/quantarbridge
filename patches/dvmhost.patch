+bool decodeHexText(const std::string& hex, std::string& text)
+{
+    if (hex.empty() || (hex.size() & 1U) != 0U || hex.size() > 4096U) {
+        return false;
+    }
+
+    auto nibble = [](char value) -> int {
+        if (value >= '0' && value <= '9') return value - '0';
+        if (value >= 'a' && value <= 'f') return 10 + value - 'a';
+        if (value >= 'A' && value <= 'F') return 10 + value - 'A';
+        return -1;
+    };
+
+    text.clear();
+    text.reserve(hex.size() / 2U);
+    for (size_t i = 0U; i < hex.size(); i += 2U) {
+        const int high = nibble(hex[i]);
+        const int low = nibble(hex[i + 1U]);
+        if (high < 0 || low < 0) {
+            text.clear();
+            return false;
+        }
+        text.push_back(static_cast<char>((high << 4U) | low));
+    }
+    return !text.empty();
+}
