+bool Data::handleMotorolaScepArsRegistration(uint32_t sourceRid, uint32_t targetRid)
+{
+    const uint8_t blocksToFollow = m_rfAssembler->dataHeader.getBlocksToFollow();
+    if (sourceRid != targetRid || m_rfPduUserDataLength != 53U || blocksToFollow != 4U ||
+        m_rfAssembler->dataHeader.getFormat() != PDUFormatType::CONFIRMED ||
+        !m_rfAssembler->dataHeader.getAckNeeded() || m_rfAssembler->getExtendedAddress() ||
+        m_rfAssembler->getUndecodableBlockCount() != 0U) {
+        return false;
+    }
+
+    std::vector<uint8_t> rawBlocks(static_cast<size_t>(blocksToFollow) * P25_PDU_CONFIRMED_DATA_LENGTH_BYTES, 0x00U);
+    for (uint8_t i = 0U; i < blocksToFollow; ++i) {
+        if (m_rfAssembler->dataBlocks[i].getFormat() != PDUFormatType::CONFIRMED ||
+            m_rfAssembler->dataBlocks[i].getSerialNo() != i ||
+            m_rfAssembler->dataBlocks[i].getData(rawBlocks.data() +
+                static_cast<size_t>(i) * P25_PDU_CONFIRMED_DATA_LENGTH_BYTES) != P25_PDU_CONFIRMED_DATA_LENGTH_BYTES) {
+            return false;
+        }
+    }
+
+    uint32_t subscriberIp = 0U;
+    uint16_t requestIpId = 0U;
+    if (!parseMotorolaScepArsRegistration(rawBlocks, sourceRid, subscriberIp, requestIpId)) {
+        return false;
+    }
+
+    m_fneRegTable[sourceRid] = subscriberIp;
+    rememberLocalSmsRid(sourceRid);
+    auto& session = m_motorolaSessions[sourceRid];
+    session.state = MotorolaSessionState::REGISTERED;
+    session.serverIdentity = sourceRid;
+    session.serverIp = g_motorolaArsServerIp;
+    session.pendingServiceAvailability = true;
+    session.serviceAvailabilityDelayMs = kMotorolaTmsServiceFallbackDelayMs;
+    session.serviceAvailabilityAttempts = 0U;
+    session.sentTmsReadyNotice = false;
+    session.nextOutboundNs = 1U;
+    session.pendingLocationRequest = false;
+    session.locationRequestDelayMs = 0U;
+    session.nextLocationRequestId = 1U;
+    LogInfoEx(LOG_RF, P25_PDU_STR ", recognized Motorola SCEP ARS registration, llId = %u, subscriberIp = %s, serverIp = %s, n = %u",
+        sourceRid, __IP_FROM_UINT(subscriberIp).c_str(), __IP_FROM_UINT(g_motorolaArsServerIp).c_str(),
+        m_rfAssembler->dataHeader.getNs());
+
+    writeRF_PDU_Ack_Response(PDUAckClass::ACK, PDUAckType::ACK,
+        m_rfAssembler->dataHeader.getNs(), sourceRid, false);
+
+    std::vector<uint8_t> response = buildMotorolaArsSuccess(subscriberIp, requestIpId);
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::CONFIRMED);
+    rspHeader.setMFId(MFG_STANDARD);
+    rspHeader.setAckNeeded(true);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::PACKET_DATA);
+    rspHeader.setLLId(sourceRid);
+    rspHeader.setSynchronize(true);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(0U);
+    rspHeader.setFSN(0U);
+    rspHeader.calculateLength(static_cast<uint32_t>(response.size()));
+
+    uint32_t bitLength = 0U;
+    UInt8Array assembled = m_rfAssembler->assemble(rspHeader, false, false, response.data(), &bitLength);
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", sending Motorola ARS registration success 0002BF01, llId = %u, subscriberIp = %s, bits = %u, packetLength = %u, pad = %u",
+        sourceRid, __IP_FROM_UINT(subscriberIp).c_str(), bitLength, rspHeader.getPacketLength(), rspHeader.getPadLength());
+    m_p25->writeRF_TDU(true, false);
+    writeRF_PDU(assembled.get(), bitLength, false);
+    return true;
+}
+
+bool Data::handleMotorolaArsRefresh(uint32_t sourceRid, uint32_t targetRid)
+{
+    if (sourceRid != targetRid || m_rfAssembler->getExtendedAddress() ||
+        m_rfAssembler->getPacketCRCFailed() ||
+        m_rfAssembler->getUndecodableBlockCount() != 0U) {
+        return false;
+    }
+
+    uint32_t subscriberIp = 0U;
+    uint16_t requestIpId = 0U;
+    if (!parseMotorolaArsRefresh(m_rfPduUserData, m_rfPduUserDataLength,
+        sourceRid, subscriberIp, requestIpId)) {
+        return false;
+    }
+
+    m_fneRegTable[sourceRid] = subscriberIp;
