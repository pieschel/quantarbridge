+void Data::writeSyntheticMotorolaPeerServiceStatus(uint32_t sourceRid, uint32_t responderRid, uint8_t ns, bool sync)
+{
+    std::string responderText = std::to_string(responderRid);
+    auto session = m_motorolaSessions.find(sourceRid);
+    if (session != m_motorolaSessions.end() &&
+        !session->second.externalArsTargetText.empty() &&
+        (session->second.externalArsTargetRid == responderRid ||
+         session->second.peerArpResponderRid == responderRid)) {
+        responderText = session->second.externalArsTargetText;
+    }
+    if (sourceRid == 0U || responderText.size() < 6U || responderText.size() > 7U) {
+        return;
+    }
+
+    const std::string displayText = std::string("B") + responderText;
+    std::vector<uint8_t> appPayload;
+    appPayload.reserve(12U + (responderText.size() * 2U) + (displayText.size() * 2U));
+    const uint8_t prefix[] = {0x00U, 0x04U, 0x00U, 0xC0U, 0x0CU};
+    appPayload.insert(appPayload.end(), prefix, prefix + sizeof(prefix));
+    for (const char ch : responderText) {
+        appPayload.push_back(static_cast<uint8_t>(ch));
+        appPayload.push_back(0x00U);
+    }
+    const uint8_t mid[] = {0x00U, 0x02U, 0x00U, 0x00U, 0x06U, 0x80U, 0x04U};
+    appPayload.insert(appPayload.end(), mid, mid + sizeof(mid));
+    for (const char ch : displayText) {
+        appPayload.push_back(static_cast<uint8_t>(ch));
+        appPayload.push_back(0x00U);
+    }
+
+    std::vector<uint8_t> response(29U + appPayload.size(), 0x00U);
+    const uint8_t fixedHeader[] = {
+        0x45U, 0x00U, 0x00U, 0x00U, 0x49U, 0x83U, 0x00U, 0x00U,
+        0x40U, 0x11U, 0x00U, 0x00U, 0x00U, 0x02U, 0x00U, 0x00U,
+        0x01U, 0x0AU, 0x00U, 0x00U, 0x02U, 0x0FU, 0xA7U, 0x0FU,
+        0x00U, 0x00U, 0x28U, 0xE6U, 0x95U
+    };
+    ::memcpy(response.data(), fixedHeader, sizeof(fixedHeader));
+    const uint16_t totalLen = static_cast<uint16_t>(response.size());
+    response[2U] = static_cast<uint8_t>((totalLen >> 8U) & 0xFFU);
+    response[3U] = static_cast<uint8_t>(totalLen & 0xFFU);
+    writeLegacyMotorolaPeerAddresses(response);
+    response[25U] = static_cast<uint8_t>(response.size() - 20U);
+    std::copy(appPayload.begin(), appPayload.end(), response.begin() + 29U);
+
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::CONFIRMED);
+    rspHeader.setAckNeeded(true);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::EXT_ADDR);
+    rspHeader.setEXSAP(PDUSAP::PACKET_DATA);
+    rspHeader.setMFId(0x00U);
+    rspHeader.setLLId(sourceRid);
+    rspHeader.setSrcLLId(responderRid);
+    rspHeader.setSynchronize(sync);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(ns & 0x07U);
+    rspHeader.setFSN(0U);
+    const uint32_t packetPayloadBytes = std::min<uint32_t>(60U, static_cast<uint32_t>(response.size()));
+    rspHeader.calculateLength(packetPayloadBytes);
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola peer service-status, srcId = %u, dstRid = %u, bytes = %u, n = %u",
+        responderRid, sourceRid, static_cast<uint32_t>(response.size()), ns & 0x07U);
+
+    std::vector<uint8_t> rawUserData(static_cast<size_t>(rspHeader.getBlocksToFollow()) * P25_PDU_CONFIRMED_DATA_LENGTH_BYTES, 0x00U);
+    rawUserData[0U] = static_cast<uint8_t>((responderRid >> 16U) & 0xFFU);
+    rawUserData[1U] = static_cast<uint8_t>((responderRid >> 8U) & 0xFFU);
+    rawUserData[2U] = static_cast<uint8_t>(responderRid & 0xFFU);
+    rawUserData[3U] = static_cast<uint8_t>(0xC0U | PDUSAP::PACKET_DATA);
+    const size_t primaryBytes = std::min<size_t>(packetPayloadBytes, response.size());
+    ::memcpy(rawUserData.data() + 4U, response.data(), primaryBytes);
+    if (response.size() > primaryBytes && (4U + primaryBytes) < rawUserData.size()) {
+        const size_t tailBytes = std::min(response.size() - primaryBytes, rawUserData.size() - 4U - primaryBytes);
+        ::memcpy(rawUserData.data() + 4U + primaryBytes, response.data() + primaryBytes, tailBytes);
+    }
+
+    uint32_t rawBitLength = 0U;
+    UInt8Array rawPdu = assembleConfirmedPduWithRawUserData(rspHeader, rawUserData, &rawBitLength);
+    const bool previousInbound = m_inbound;
+    m_inbound = true;
+    writeRF_PDU(rawPdu.get(), rawBitLength, true);
+    m_inbound = previousInbound;
+}
