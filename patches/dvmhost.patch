+void addDMRPacketCRC32(uint8_t* packetData, uint32_t packetLength, uint32_t padLength)
+{
+    const uint32_t crcLength = packetLength + padLength + 4U;
+    const uint32_t dataLength = crcLength - 4U;
+    DECLARE_UINT8_ARRAY(crcBytes, crcLength);
+
+    // DMR packet-data CRC is computed over a 16-bit byte-swapped view of the
+    // payload, while the transmitted payload itself stays in normal byte order.
+    for (uint32_t i = 0U; i + 1U < dataLength; i += 2U) {
+        crcBytes[i] = packetData[i + 1U];
+        crcBytes[i + 1U] = packetData[i];
+    }
+
+    edac::CRC::addInvertedCRC32(crcBytes, crcLength);
+
+    packetData[dataLength + 0U] = crcBytes[crcLength - 1U];
+    packetData[dataLength + 1U] = crcBytes[crcLength - 2U];
+    packetData[dataLength + 2U] = crcBytes[crcLength - 3U];
+    packetData[dataLength + 3U] = crcBytes[crcLength - 4U];
+}
+
+}
