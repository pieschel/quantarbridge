+void Data::writeSyntheticMotorolaArpRequest(uint32_t targetRid, uint32_t responderRid)
+{
+    uint32_t targetIp = g_motorolaArsServerIp;
+    const auto targetReg = m_fneRegTable.find(targetRid);
+    if (targetReg != m_fneRegTable.end() && targetReg->second != 0U) {
+        targetIp = targetReg->second;
+    }
+    const uint32_t responderIp = g_motorolaArsPeerIp;
+
+    std::vector<uint8_t> arpPacket(P25_PDU_ARP_PCKT_LENGTH, 0x00U);
+    arpPacket[0U] = 0x00U;
+    arpPacket[1U] = P25_PDU_ARP_CAI_TYPE;
+    arpPacket[2U] = 0x00U;
+    arpPacket[3U] = PDUSAP::PACKET_DATA;
+    arpPacket[4U] = P25_PDU_ARP_HW_ADDR_LENGTH;
+    arpPacket[5U] = P25_PDU_ARP_PROTO_ADDR_LENGTH;
+    arpPacket[6U] = 0x00U;
+    arpPacket[7U] = P25_PDU_ARP_REQUEST;
+    arpPacket[8U] = static_cast<uint8_t>((responderRid >> 16) & 0xFFU);
+    arpPacket[9U] = static_cast<uint8_t>((responderRid >> 8) & 0xFFU);
+    arpPacket[10U] = static_cast<uint8_t>(responderRid & 0xFFU);
+    arpPacket[11U] = static_cast<uint8_t>((responderIp >> 24) & 0xFFU);
+    arpPacket[12U] = static_cast<uint8_t>((responderIp >> 16) & 0xFFU);
+    arpPacket[13U] = static_cast<uint8_t>((responderIp >> 8) & 0xFFU);
+    arpPacket[14U] = static_cast<uint8_t>(responderIp & 0xFFU);
+    arpPacket[18U] = static_cast<uint8_t>((targetIp >> 24) & 0xFFU);
+    arpPacket[19U] = static_cast<uint8_t>((targetIp >> 16) & 0xFFU);
+    arpPacket[20U] = static_cast<uint8_t>((targetIp >> 8) & 0xFFU);
+    arpPacket[21U] = static_cast<uint8_t>(targetIp & 0xFFU);
+
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::UNCONFIRMED);
+    rspHeader.setAckNeeded(false);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::EXT_ADDR);
+    rspHeader.setEXSAP(PDUSAP::ARP);
+    rspHeader.setMFId(0x00U);
+    rspHeader.setLLId(WUID_ALL);
+    rspHeader.setSrcLLId(responderRid);
+    rspHeader.setSynchronize(false);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(0U);
+    rspHeader.setFSN(0U);
+    rspHeader.calculateLength(static_cast<uint32_t>(arpPacket.size()));
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola ARP request, srcId = %u, targetRid = %u, targetIp = %s",
+        responderRid, targetRid, __IP_FROM_UINT(targetIp).c_str());
+    const bool previousInbound = m_inbound;
+    m_inbound = true;
+    writeRF_PDU_User(rspHeader, true, false, arpPacket.data(), false);
+    m_inbound = previousInbound;
+}
