+void Data::writeSyntheticMotorolaFollowup(uint32_t sourceRid, uint32_t responderRid)
+{
+    {
+    std::string responderText = std::to_string(responderRid);
+    auto session = m_motorolaSessions.find(sourceRid);
+    if (session != m_motorolaSessions.end() &&
+        session->second.externalArsTargetRid != 0U &&
+        responderRid != kMotorolaExternalRfProxyRid &&
+        !session->second.externalArsTargetText.empty()) {
+        responderText = session->second.externalArsTargetText;
+    }
+    if (responderText.size() < 6U || responderText.size() > 7U) {
+        LogWarning(LOG_RF, P25_PDU_STR ", Motorola peer follow-up skipped, responder RID text is invalid, responderRid = %u",
+            responderRid);
+        return;
+    }
+    const bool acceptedPeerPacket = session != m_motorolaSessions.end() && session->second.sentPeerServiceStatus;
+    const uint8_t followupNs = nextMotorolaPacketNs(responderRid, sourceRid, acceptedPeerPacket ? 1U : 0U);
+
+    const uint16_t motorolaPeerChecksum = motorolaPeerChecksumForRidText(responderText);
+    const uint32_t packetLength = static_cast<uint32_t>(37U + responderText.size());
+    std::vector<uint8_t> peerPayload(packetLength, 0x00U);
+    const uint8_t fixedHeader[] = {
+        0x45U, 0x00U, 0x00U, 0x00U, 0x44U, 0x42U, 0x00U, 0x00U,
+        0x40U, 0x11U, 0x00U, 0x00U, 0x00U, 0x02U, 0x00U, 0x00U,
+        0x01U, 0x0AU, 0x00U, 0x00U, 0x02U, 0x0FU, 0xA5U, 0x0FU,
+        0xA5U, 0x00U, 0x00U, 0x00U, 0x00U, 0x00U, 0x04U, 0x00U,
+        0x3FU, 0x00U,
+    };
+    ::memcpy(peerPayload.data(), fixedHeader, sizeof(fixedHeader));
+    peerPayload[2U] = static_cast<uint8_t>((packetLength >> 8U) & 0xFFU);
+    peerPayload[3U] = static_cast<uint8_t>(packetLength & 0xFFU);
+    if (responderText.size() == 6U) {
+        peerPayload[4U] = 0x50U;
+        peerPayload[5U] = 0x53U;
+        peerPayload[10U] = 0x12U;
+        peerPayload[11U] = 0xE7U;
+    } else {
+        peerPayload[4U] = 0x44U;
+        peerPayload[5U] = 0x42U;
+        peerPayload[10U] = 0x1EU;
+        peerPayload[11U] = 0xF7U;
+    }
+    writeLegacyMotorolaPeerAddresses(peerPayload);
+    peerPayload[25U] = 0x00U;
+    peerPayload[26U] = static_cast<uint8_t>(0x11U + responderText.size());
+    peerPayload[27U] = static_cast<uint8_t>((motorolaPeerChecksum >> 8U) & 0xFFU);
+    peerPayload[28U] = static_cast<uint8_t>(motorolaPeerChecksum & 0xFFU);
+    peerPayload[33U] = static_cast<uint8_t>(responderText.size());
+    ::memcpy(peerPayload.data() + 34U, responderText.data(), responderText.size());
+    const size_t suffixOffset = 34U + responderText.size();
+    peerPayload[suffixOffset] = 0x04U;
+    peerPayload[suffixOffset + 1U] = static_cast<uint8_t>((g_motorolaArsPeerIp >> 24U) & 0xFFU);
+    peerPayload[suffixOffset + 2U] = static_cast<uint8_t>((g_motorolaArsPeerIp >> 16U) & 0xFFU);
+
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::CONFIRMED);
+    rspHeader.setAckNeeded(true);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::EXT_ADDR);
+    rspHeader.setEXSAP(PDUSAP::PACKET_DATA);
+    rspHeader.setMFId(0x00U);
+    rspHeader.setLLId(sourceRid);
+    rspHeader.setSrcLLId(responderRid);
+    rspHeader.setSynchronize(false);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(followupNs);
+    rspHeader.setFSN(0U);
+    rspHeader.calculateLength(static_cast<uint32_t>(peerPayload.size()));
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", reassembled Motorola peer follow-up, srcId = %u, dstRid = %u, bytes = %u, n = %u, pduPacketLength = %u, padLength = %u, peerChecksum = $%04X",
+        responderRid, sourceRid, static_cast<uint32_t>(peerPayload.size()), followupNs, rspHeader.getPacketLength(), rspHeader.getPadLength(), motorolaPeerChecksum);
+
+    std::vector<uint8_t> rawUserData(static_cast<size_t>(rspHeader.getBlocksToFollow()) * P25_PDU_CONFIRMED_DATA_LENGTH_BYTES, 0x00U);
+    rawUserData[0U] = static_cast<uint8_t>((responderRid >> 16U) & 0xFFU);
+    rawUserData[1U] = static_cast<uint8_t>((responderRid >> 8U) & 0xFFU);
+    rawUserData[2U] = static_cast<uint8_t>(responderRid & 0xFFU);
+    rawUserData[3U] = static_cast<uint8_t>(0xC0U | PDUSAP::PACKET_DATA);
+    ::memcpy(rawUserData.data() + 4U, peerPayload.data(), peerPayload.size());
+    const uint8_t motorolaTail[] = {
+        0x01U, 0x01U, 0x00U, 0x00U, 0x02U, 0x00U, 0x00U, 0x06U,
+        0x00U, 0x00U, 0x00U, 0x00U, 0x00U, 0x00U, 0x00U, 0x00U,
+        0x00U
+    };
+    const size_t tailOffset = 4U + peerPayload.size();
+    if (tailOffset < rawUserData.size()) {
+        const size_t tailBytes = std::min(sizeof(motorolaTail), rawUserData.size() - tailOffset);
+        ::memcpy(rawUserData.data() + tailOffset, motorolaTail, tailBytes);
+    }
+
+    uint32_t rawBitLength = 0U;
+    UInt8Array rawPdu = assembleConfirmedPduWithRawUserData(rspHeader, rawUserData, &rawBitLength);
+    const bool previousInbound = m_inbound;
+    m_inbound = true;
+    writeRF_PDU(rawPdu.get(), rawBitLength, false);
+    m_inbound = previousInbound;
+    return;
+    }
+
+}
