+void Data::writeSyntheticMotorolaArsResponse(uint32_t sourceRid, uint32_t targetRid, const uint8_t* pduUserData, uint32_t length)
+{
+    if (pduUserData != nullptr && length < 28U) {
+        return;
+    }
+
+    if (pduUserData != nullptr) {
+        uint32_t rfResponderRid = motorolaRfResponderRid(targetRid);
+        auto responseSession = m_motorolaSessions.find(sourceRid);
+        if (responseSession != m_motorolaSessions.end() && responseSession->second.peerArpResponderRid != 0U) {
+            rfResponderRid = responseSession->second.peerArpResponderRid;
+        }
+        std::string responderText = motorolaRidText(rfResponderRid);
+        std::string requesterText = motorolaRidText(sourceRid);
+        if (length >= 34U && pduUserData[0U] == 0x45U && pduUserData[9U] == 0x11U) {
+            const uint8_t* udpPayload = pduUserData + 28U;
+            const uint32_t udpPayloadLength = length - 28U;
+            if (udpPayloadLength >= 6U && udpPayload[0U] == 0x00U && udpPayload[2U] == 0x72U) {
+                const uint32_t sourceLen = udpPayload[3U];
+                const uint32_t targetLenOffset = 4U + sourceLen;
+                if (sourceLen > 0U && sourceLen <= 10U && targetLenOffset < udpPayloadLength) {
+                    const uint32_t targetLen = udpPayload[targetLenOffset];
+                    if (targetLen > 0U && targetLen <= 10U && targetLenOffset + 1U + targetLen <= udpPayloadLength) {
+                        std::string requestedSource(reinterpret_cast<const char*>(udpPayload + 4U), sourceLen);
+                        std::string requestedTarget(reinterpret_cast<const char*>(udpPayload + targetLenOffset + 1U), targetLen);
+                        if (requestedSource.find_first_not_of("0123456789") == std::string::npos &&
+                            requestedTarget.find_first_not_of("0123456789") == std::string::npos) {
+                            try {
+                                if (static_cast<uint32_t>(std::stoul(requestedSource)) == sourceRid) {
+                                    requesterText = requestedSource;
+                                }
+                                if (static_cast<uint32_t>(std::stoul(requestedTarget)) == targetRid) {
+                                    responderText = requestedTarget;
+                                    if (responseSession != m_motorolaSessions.end()) {
+                                        responseSession->second.externalArsTargetText = requestedTarget;
+                                    }
+                                }
+                            } catch (...) {
+                            }
+                        }
+                    }
+                }
+            }
+        }
+        const uint32_t payloadLength = std::max<uint32_t>(19U, static_cast<uint32_t>(responderText.size() + requesterText.size() + 5U));
+        const uint32_t ipPacketLength = 28U + payloadLength;
+        if (length < 28U || responderText.empty() || requesterText.empty() ||
+            responderText.size() > 7U || requesterText.size() > 7U) {
+            return;
+        }
+
+        std::vector<uint8_t> response(ipPacketLength, 0x00U);
+        ::memcpy(response.data(), pduUserData, std::min(length, ipPacketLength));
+        response[2U] = static_cast<uint8_t>((ipPacketLength >> 8) & 0xFFU);
+        response[3U] = static_cast<uint8_t>(ipPacketLength & 0xFFU);
+        response[10U] = 0x00U;
+        response[11U] = 0x00U;
+        response[12U] = 0x01U;
+        response[13U] = 0x02U;
+        response[14U] = 0x84U;
+        response[15U] = 0x22U;
+        response[16U] = pduUserData[12U];
+        response[17U] = pduUserData[13U];
+        response[18U] = pduUserData[14U];
+        response[19U] = pduUserData[15U];
+        const uint16_t udpLength = static_cast<uint16_t>(8U + payloadLength);
+        response[24U] = static_cast<uint8_t>((udpLength >> 8) & 0xFFU);
+        response[25U] = static_cast<uint8_t>(udpLength & 0xFFU);
+        const uint16_t ipCsum = checksum16(response.data(), 20U);
+        response[10U] = static_cast<uint8_t>((ipCsum >> 8) & 0xFFU);
+        response[11U] = static_cast<uint8_t>(ipCsum & 0xFFU);
+
+        std::fill(response.begin() + 28U, response.end(), 0x00U);
+        uint32_t pos = 28U;
+        for (const char ch : responderText) {
+            response[pos++] = static_cast<uint8_t>(ch);
+        }
+        response[pos++] = 0x35U;
+        for (const char ch : requesterText) {
+            response[pos++] = static_cast<uint8_t>(ch);
+        }
+        response[pos++] = 0x33U;
+        while (pos < response.size()) {
+            response[pos++] = 0x00U;
+        }
+
+        response[26U] = pduUserData[26U];
+        response[27U] = pduUserData[27U];
+
+        data::DataHeader rspHeader = data::DataHeader();
+        rspHeader.setFormat(PDUFormatType::CONFIRMED);
+        rspHeader.setAckNeeded(true);
+        rspHeader.setOutbound(true);
+        rspHeader.setSAP(PDUSAP::EXT_ADDR);
+        rspHeader.setEXSAP(PDUSAP::PACKET_DATA);
+        rspHeader.setMFId(0x00U);
+        rspHeader.setLLId(sourceRid);
+        rspHeader.setSrcLLId(rfResponderRid);
+        rspHeader.setSynchronize(false);
+        rspHeader.setLastFragment(true);
+        rspHeader.setNs(0U);
+        rspHeader.setFSN(0U);
+        rspHeader.calculateLength(static_cast<uint32_t>(response.size()));
+
+        LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola ARS bootstrap response, srcId = %u, dstRid = %u, bmTargetRid = %u, n = 0",
+            rfResponderRid, sourceRid, targetRid);
+        writeRF_PDU_User(rspHeader, true, false, response.data(), true);
+        return;
+    }
+
+    uint32_t responderRid = motorolaRfResponderRid(targetRid);
+    auto session = m_motorolaSessions.find(sourceRid);
+    if (session != m_motorolaSessions.end() && session->second.serverIdentity != 0U &&
+        session->second.externalArsTargetRid == 0U) {
+        responderRid = session->second.serverIdentity;
+    }
+
+    std::ostringstream responderStream;
+    responderStream << std::setw(7) << std::setfill('0') << responderRid;
+    const std::string responderText = responderStream.str();
+    if (responderText.size() != 7U) {
+        return;
+    }
+
+    std::vector<uint8_t> payload;
+    payload.reserve(16U);
+    const uint8_t prefix[] = {0x76U, 0x00U, 0x04U, 0x00U, 0x3FU};
+    payload.insert(payload.end(), prefix, prefix + sizeof(prefix));
+    payload.push_back(0x07U);
+    payload.insert(payload.end(), responderText.begin(), responderText.end());
+    payload.push_back(0x04U);
+    uint8_t sourceIpPrefix0 = static_cast<uint8_t>((g_motorolaArsPeerIp >> 24U) & 0xFFU);
+    uint8_t sourceIpPrefix1 = static_cast<uint8_t>((g_motorolaArsPeerIp >> 16U) & 0xFFU);
+    if (pduUserData != nullptr && length >= 14U) {
+        sourceIpPrefix0 = pduUserData[12U];
+        sourceIpPrefix1 = pduUserData[13U];
+    } else if (session != m_motorolaSessions.end() &&
+        (session->second.externalArsIpPrefix0 != 0U || session->second.externalArsIpPrefix1 != 0U)) {
+        sourceIpPrefix0 = session->second.externalArsIpPrefix0;
+        sourceIpPrefix1 = session->second.externalArsIpPrefix1;
+    } else {
+        const auto reg = m_fneRegTable.find(sourceRid);
+        if (reg != m_fneRegTable.end() && reg->second != 0U) {
+            sourceIpPrefix0 = static_cast<uint8_t>((reg->second >> 24) & 0xFFU);
+            sourceIpPrefix1 = static_cast<uint8_t>((reg->second >> 16) & 0xFFU);
+        }
+    }
+    payload.push_back(sourceIpPrefix0);
+    payload.push_back(sourceIpPrefix1);
+
+    if (payload.size() != 16U) {
+        return;
+    }
+
+    // This is the accepted APX peer envelope from the A<->B reference exchange.
+    // The bytes at offsets 24..27 are intentionally not recomputed as normal UDP
+    // length/checksum fields; the accepted Motorola peer frame carries them as
+    // a fixed 0xA5 00 18 B3 marker.
+    const uint8_t peerHeader[] = {
+        0x45U, 0x00U, 0x00U, 0x2CU, 0xB7U, 0x7FU, 0x00U, 0x00U,
+        0x40U, 0x11U, 0x00U, 0x00U, 0x00U, 0x02U, 0x00U, 0x00U,
+        0x01U, 0x0AU, 0x00U, 0x00U, 0x02U, 0x0FU, 0xA5U, 0x0FU,
+        0xA5U, 0x00U, 0x18U, 0xB3U,
+    };
+    std::vector<uint8_t> response(peerHeader, peerHeader + sizeof(peerHeader));
+    response.insert(response.end(), payload.begin(), payload.end());
+    writeLegacyMotorolaPeerAddresses(response);
+
+    const uint8_t ns = 0U;
+
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::CONFIRMED);
+    rspHeader.setAckNeeded(true);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::EXT_ADDR);
+    rspHeader.setEXSAP(PDUSAP::PACKET_DATA);
+    rspHeader.setMFId(0x00U);
+    rspHeader.setLLId(sourceRid);
+    rspHeader.setSrcLLId(responderRid);
+    rspHeader.setSynchronize(false);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(ns);
+    rspHeader.setFSN(0U);
+    rspHeader.calculateLength(static_cast<uint32_t>(response.size()));
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola ARS response, srcId = %u, dstRid = %u, n = %u",
+        responderRid, sourceRid, ns);
+    writeRF_PDU_User(rspHeader, true, false, response.data(), true);
+}
+
+void Data::writeSyntheticMotorolaArsPresence(uint32_t sourceRid, uint32_t targetRid)
+{
+    if (sourceRid == 0U || sourceRid == WUID_ALL || targetRid == 0U || targetRid == WUID_ALL) {
+        return;
+    }
+
+    const std::string sourceText = std::to_string(sourceRid);
+    const std::string targetText = motorolaRidText(targetRid);
+    if (sourceText.empty() || sourceText.size() > 10U || targetText.empty() || targetText.size() > 10U) {
+        return;
+    }
+
+    std::vector<uint8_t> payload;
+    payload.reserve(5U + sourceText.size() + targetText.size());
+    payload.push_back(0x00U);
+    payload.push_back(0x00U);
+    payload.push_back(0x72U);
+    payload.push_back(static_cast<uint8_t>(sourceText.size()));
+    payload.insert(payload.end(), sourceText.begin(), sourceText.end());
+    payload.push_back(static_cast<uint8_t>(targetText.size()));
+    payload.insert(payload.end(), targetText.begin(), targetText.end());
+    payload[1U] = static_cast<uint8_t>(payload.size() - 2U);
+
+    const uint16_t ipPacketLength = static_cast<uint16_t>(28U + payload.size());
+    std::vector<uint8_t> response(ipPacketLength, 0x00U);
+    response[0U] = 0x45U;
+    response[2U] = static_cast<uint8_t>((ipPacketLength >> 8U) & 0xFFU);
+    response[3U] = static_cast<uint8_t>(ipPacketLength & 0xFFU);
+    response[4U] = 0x3DU;
+    response[5U] = 0xD6U;
+    response[8U] = 0x40U;
+    response[9U] = 0x11U;
+    writeUint32BE(response, 12U, g_motorolaArsPeerIp);
+    response[16U] = 0xFFU;
+    response[17U] = 0xFFU;
+    response[18U] = 0xFFU;
+    response[19U] = 0xFFU;
+    response[20U] = 0x0FU;
+    response[21U] = 0xA5U;
+    response[22U] = 0x0FU;
+    response[23U] = 0xA5U;
+    const uint16_t udpLength = static_cast<uint16_t>(8U + payload.size());
+    response[24U] = static_cast<uint8_t>((udpLength >> 8U) & 0xFFU);
+    response[25U] = static_cast<uint8_t>(udpLength & 0xFFU);
+    std::copy(payload.begin(), payload.end(), response.begin() + 28U);
+
+    response[10U] = 0x00U;
+    response[11U] = 0x00U;
+    const uint16_t ipCsum = checksum16(response.data(), 20U);
+    response[10U] = static_cast<uint8_t>((ipCsum >> 8U) & 0xFFU);
+    response[11U] = static_cast<uint8_t>(ipCsum & 0xFFU);
+
+    response[26U] = 0x00U;
+    response[27U] = 0x00U;
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), response.begin() + 12U, response.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+    pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), response.begin() + 20U, response.end());
+    const uint16_t udpCsum = checksum16(pseudo.data(), pseudo.size());
+    response[26U] = static_cast<uint8_t>((udpCsum >> 8U) & 0xFFU);
+    response[27U] = static_cast<uint8_t>(udpCsum & 0xFFU);
+
+    data::DataHeader rspHeader = data::DataHeader();
+    rspHeader.setFormat(PDUFormatType::UNCONFIRMED);
+    rspHeader.setAckNeeded(false);
+    rspHeader.setOutbound(true);
+    rspHeader.setSAP(PDUSAP::EXT_ADDR);
+    rspHeader.setEXSAP(PDUSAP::PACKET_DATA);
+    rspHeader.setMFId(0x00U);
+    rspHeader.setLLId(WUID_ALL);
+    rspHeader.setSrcLLId(sourceRid);
+    rspHeader.setSynchronize(false);
+    rspHeader.setLastFragment(true);
+    rspHeader.setNs(0U);
+    rspHeader.setFSN(0U);
+    rspHeader.calculateLength(static_cast<uint32_t>(response.size()));
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola ARS presence, srcId = %u, targetRid = %u",
+        sourceRid, targetRid);
+    writeRF_PDU_User(rspHeader, true, false, response.data(), true);
+}
+
+void Data::writeSyntheticMotorolaTmsDeliveryAck(uint32_t sourceRid, uint32_t responderRid, const uint8_t* pduUserData, uint32_t length, uint8_t ns)
+{
+    if (pduUserData == nullptr || length < 29U || responderRid == 0U || responderRid > 9999999U) {
