+
+bool isLocalSmsRid(uint32_t rid)
+{
+    if (rid == 0U || rid == 16777215U) {
+        return false;
+    }
+    const auto now = std::chrono::steady_clock::now();
+    for (auto it = g_localSmsRids.begin(); it != g_localSmsRids.end();) {
+        if (it->second <= now) {
+            it = g_localSmsRids.erase(it);
+        } else {
+            ++it;
+        }
+    }
+    return g_localSmsRids.find(rid) != g_localSmsRids.end();
