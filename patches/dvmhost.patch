+        const float alpha = std::sin(omega) / (2.0f * butterworthQ);
+        const float a0 = 1.0f + alpha;
+        const float b0 = ((1.0f - cosine) * 0.5f) / a0;
+        const float b1 = (1.0f - cosine) / a0;
+        const float b2 = b0;
+        const float a1 = (-2.0f * cosine) / a0;
+        const float a2 = (1.0f - alpha) / a0;
