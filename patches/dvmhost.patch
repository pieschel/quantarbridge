@@ -33,8 +33,169 @@ using namespace network::udp;
 #include <cstdio>
 #include <algorithm>
 #include <functional>
+#include <cmath>
 #include <random>
 
+namespace
+{
+    constexpr int SHORT_CLIP_SMPL_MIN = -32767;
+    constexpr int SHORT_CLIP_SMPL_MAX = 32767;
+
+    short clipPcmSample(int sample)
+    {
+        if (sample > SHORT_CLIP_SMPL_MAX)
+            sample = SHORT_CLIP_SMPL_MAX;
+        else if (sample < SHORT_CLIP_SMPL_MIN)
+            sample = SHORT_CLIP_SMPL_MIN;
+
+        return static_cast<short>(sample);
+    }
+
+    void applyP25PeakProtectedGain(short* samples, int length, float requestedGain,
+        float peakLimit, float& limiterScale, uint32_t& protectedFrames)
+    {
+        if (samples == nullptr || length <= 0)
+            return;
+        if (requestedGain <= 0.0f) {
+            ::memset(samples, 0x00U, static_cast<size_t>(length) * sizeof(short));
+            limiterScale = 1.0f;
+            return;
+        }
+
+        constexpr float release = 0.08f;
+        if (peakLimit < 1.0f)
+            peakLimit = 1.0f;
+        if (peakLimit > static_cast<float>(SHORT_CLIP_SMPL_MAX))
+            peakLimit = static_cast<float>(SHORT_CLIP_SMPL_MAX);
+
+        int peak = 0;
+        for (int i = 0; i < length; ++i) {
+            const int sample = static_cast<int>(samples[i]);
+            const int magnitude = sample < 0 ? -sample : sample;
+            if (magnitude > peak)
+                peak = magnitude;
+        }
+
+        float desiredScale = 1.0f;
+        if (peak > 0 && static_cast<float>(peak) * requestedGain > peakLimit) {
+            desiredScale = peakLimit / (static_cast<float>(peak) * requestedGain);
+            ++protectedFrames;
+            if (protectedFrames == 1U || (protectedFrames % 250U) == 0U) {
+                LogInfoEx(LOG_HOST, "P25 encoder peak protection, frames = %u, inputPeak = %d, requestedGain = %.2f, scale = %.3f",
+                    protectedFrames, peak, requestedGain, desiredScale);
+            }
+        }
+
+        if (desiredScale < limiterScale)
+            limiterScale = desiredScale;
+        else
+            limiterScale += (desiredScale - limiterScale) * release;
+
+        const float appliedGain = requestedGain * limiterScale;
+        const int outputLimit = static_cast<int>(peakLimit);
+        for (int i = 0; i < length; ++i) {
+            int adjusted = static_cast<int>(std::lround(static_cast<float>(samples[i]) * appliedGain));
+            if (adjusted > outputLimit)
+                adjusted = outputLimit;
+            else if (adjusted < -outputLimit)
+                adjusted = -outputLimit;
+            samples[i] = clipPcmSample(adjusted);
+        }
+    }
+
+    void applyP25EncodePresence(short* samples, int length, float amount)
+    {
+        if (samples == nullptr || length <= 1 || amount <= 0.0f)
+            return;
+
+        short previous = samples[0];
+        for (int i = 1; i < length; ++i) {
+            const short current = samples[i];
+            const int emphasis = static_cast<int>((static_cast<int>(current) - static_cast<int>(previous)) * amount);
+            samples[i] = clipPcmSample(static_cast<int>(current) + emphasis);
+            previous = current;
+        }
+    }
+
+    void applyP25EncodeHighCut(short* samples, int length, float cutoffHz, float& state1, float& state2)
+    {
+        if (samples == nullptr || length <= 0 || cutoffHz <= 0.0f)
+            return;
+
+        constexpr float sampleRate = 8000.0f;
+        constexpr float butterworthQ = 0.70710678f;
+        constexpr float pi = 3.14159265358979323846f;
+        const float omega = 2.0f * pi * cutoffHz / sampleRate;
+        const float cosine = std::cos(omega);
+        const float alpha = std::sin(omega) / (2.0f * butterworthQ);
+        const float a0 = 1.0f + alpha;
+        const float b0 = ((1.0f - cosine) * 0.5f) / a0;
+        const float b1 = (1.0f - cosine) / a0;
+        const float b2 = b0;
+        const float a1 = (-2.0f * cosine) / a0;
+        const float a2 = (1.0f - alpha) / a0;
+
+        for (int i = 0; i < length; ++i) {
+            const float input = static_cast<float>(samples[i]);
+            const float output = b0 * input + state1;
+            state1 = b1 * input - a1 * output + state2;
+            state2 = b2 * input - a2 * output;
+            samples[i] = clipPcmSample(static_cast<int>(std::lround(output)));
+        }
+    }
+
+    void applyP25EncodeAgc(short* samples, int length, bool enabled, float& currentGain,
+        float targetRms, float minGain, float maxGain, float attack, float release, float peakLimit)
+    {
+        if (samples == nullptr || length <= 0 || !enabled)
+            return;
+
+        double sumSquares = 0.0;
+        float peak = 0.0f;
+        for (int i = 0; i < length; ++i) {
+            const float sample = static_cast<float>(samples[i]);
+            const float absSample = std::fabs(sample);
+            sumSquares += static_cast<double>(sample) * static_cast<double>(sample);
+            if (absSample > peak)
+                peak = absSample;
+        }
+
+        const float rms = static_cast<float>(std::sqrt(sumSquares / static_cast<double>(length)));
+        if (rms < 250.0f || peak < 500.0f) {
+            currentGain += (1.0f - currentGain) * release;
+            return;
+        }
+
+        float desiredGain = targetRms / rms;
+        if (desiredGain < minGain)
+            desiredGain = minGain;
+        if (desiredGain > maxGain)
+            desiredGain = maxGain;
+
+        if (peak > 0.0f && desiredGain * peak > peakLimit)
+            desiredGain = peakLimit / peak;
+        if (desiredGain < minGain)
+            desiredGain = minGain;
+
+        const float rate = (desiredGain < currentGain) ? attack : release;
+        currentGain += (desiredGain - currentGain) * rate;
+        if (currentGain < minGain)
+            currentGain = minGain;
+        if (currentGain > maxGain)
+            currentGain = maxGain;
+
+        for (int i = 0; i < length; ++i) {
+            int adjusted = static_cast<int>(static_cast<float>(samples[i]) * currentGain);
+            if (adjusted > static_cast<int>(peakLimit))
+                adjusted = static_cast<int>(peakLimit);
+            else if (adjusted < -static_cast<int>(peakLimit))
+                adjusted = -static_cast<int>(peakLimit);
+
+            samples[i] = clipPcmSample(adjusted);
+        }
+    }
+}
