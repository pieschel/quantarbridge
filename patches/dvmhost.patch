+bool Data::handleMotorolaLocationReport(uint32_t sourceRid, uint32_t targetRid)
+{
+    if (sourceRid != targetRid || m_rfAssembler->getExtendedAddress() ||
+        m_rfAssembler->getPacketCRCFailed() ||
+        m_rfAssembler->getUndecodableBlockCount() != 0U) {
+        return false;
+    }
+
+    const auto registration = m_fneRegTable.find(sourceRid);
+    auto session = m_motorolaSessions.find(sourceRid);
+    uint8_t reportType = 0U;
+    uint16_t sourcePort = 0U;
+    bool hasPosition = false;
+    uint32_t resultCode = kMotorolaLrrpResultUnknown;
+    if (registration == m_fneRegTable.end() || session == m_motorolaSessions.end() ||
+        !parseMotorolaLocationReport(m_rfPduUserData, m_rfPduUserDataLength,
+            registration->second, reportType, sourcePort, hasPosition,
+            resultCode)) {
+        return false;
+    }
+
+    if (m_rfAssembler->dataHeader.getAckNeeded()) {
+        writeRF_PDU_Ack_Response(PDUAckClass::ACK, PDUAckType::ACK,
+            m_rfAssembler->dataHeader.getNs(), sourceRid, false);
+    }
+
+    session->second.pendingLocationRequest = true;
+    if (!hasPosition) {
+        session->second.locationRequestDelayMs = m_motorolaLocationNoFixRetryMs;
+        if (resultCode == 0x200U) {
+            LogWarning(LOG_RF, P25_PDU_STR ", Motorola LRRP response has no usable position: GPS fix is not accurate enough, sourceRid = %u, resultCode = $%X; retrying in %u seconds",
+                sourceRid, resultCode, m_motorolaLocationNoFixRetryMs / 1000U);
+        } else if (resultCode == 0x10U) {
+            LogWarning(LOG_RF, P25_PDU_STR ", Motorola LRRP response has no usable position: GPS is unavailable, sourceRid = %u, resultCode = $%X; retrying in %u seconds",
+                sourceRid, resultCode, m_motorolaLocationNoFixRetryMs / 1000U);
+        } else if (resultCode == 0x0AU) {
+            LogWarning(LOG_RF, P25_PDU_STR ", Motorola LRRP request was rejected as unsupported, sourceRid = %u, resultCode = $%X; retrying in %u seconds",
+                sourceRid, resultCode, m_motorolaLocationNoFixRetryMs / 1000U);
+        } else {
+            LogWarning(LOG_RF, P25_PDU_STR ", Motorola LRRP response has no usable position, sourceRid = %u, resultCode = $%X; retrying in %u seconds",
+                sourceRid, resultCode, m_motorolaLocationNoFixRetryMs / 1000U);
+        }
+        return true;
+    }
+
+    writeSmsRawIpPacketEvent("motorola_lrrp", sourceRid,
+        kBrandmeisterLocationRid, m_rfPduUserData, m_rfPduUserDataLength,
+        false, false);
+    session->second.locationRequestDelayMs = m_motorolaLocationIntervalMs;
+    LogInfoEx(LOG_RF, P25_PDU_STR ", Motorola LRRP location report received, sourceRid = %u, reportType = $%02X, sourcePort = %u, forwardingTargetRid = %u, bytes = %u",
+        sourceRid, reportType, sourcePort, kBrandmeisterLocationRid,
+        m_rfPduUserDataLength);
+    return true;
+}
