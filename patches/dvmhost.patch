+std::vector<std::pair<uint32_t, uint32_t>> loadMotorolaVirtualPeerTargets()
+{
+    std::vector<std::pair<uint32_t, uint32_t>> peers;
+    std::ifstream input(kMotorolaVirtualPeerCachePath);
+    if (!input.is_open()) {
+        return peers;
+    }
+
+    uint32_t sourceRid = 0U;
+    uint32_t targetRid = 0U;
+    while (input >> sourceRid >> targetRid) {
+        if (sourceRid != 0U && targetRid != 0U && targetRid <= 9999999U) {
+            peers.push_back(std::make_pair(sourceRid, targetRid));
+        }
+    }
+
+    return peers;
+}
+
+void rememberMotorolaVirtualPeerTarget(uint32_t sourceRid, uint32_t targetRid)
+{
+    if (sourceRid == 0U || targetRid == 0U || targetRid > 9999999U) {
+        return;
+    }
+
+    auto peers = loadMotorolaVirtualPeerTargets();
+    bool updated = false;
+    for (auto& peer : peers) {
+        if (peer.first == sourceRid) {
+            peer.second = targetRid;
+            updated = true;
+            break;
+        }
+    }
+    if (!updated) {
+        peers.push_back(std::make_pair(sourceRid, targetRid));
+    }
+
+    std::ofstream output(kMotorolaVirtualPeerCachePath, std::ios::trunc);
+    if (!output.is_open()) {
+        return;
+    }
+
+    for (const auto& peer : peers) {
+        output << peer.first << ' ' << peer.second << '\n';
+    }
+}
+
+uint16_t checksum16(const uint8_t* data, size_t len)
+{
+    uint32_t sum = 0U;
+    for (size_t i = 0; i + 1 < len; i += 2) {
+        sum += (static_cast<uint16_t>(data[i]) << 8) | data[i + 1U];
+    }
+    if ((len & 1U) != 0U) {
+        sum += static_cast<uint16_t>(data[len - 1U]) << 8;
+    }
+    while ((sum >> 16) != 0U) {
+        sum = (sum & 0xFFFFU) + (sum >> 16);
+    }
+    return static_cast<uint16_t>(~sum);
+}
+
+uint16_t readUint16BE(const uint8_t* data)
+{
+    return (static_cast<uint16_t>(data[0U]) << 8U) | data[1U];
+}
+
+uint32_t readUint32BE(const uint8_t* data)
+{
+    return (static_cast<uint32_t>(data[0U]) << 24U) |
+        (static_cast<uint32_t>(data[1U]) << 16U) |
+        (static_cast<uint32_t>(data[2U]) << 8U) |
+        data[3U];
+}
+
+void writeUint16BE(std::vector<uint8_t>& data, size_t offset, uint16_t value)
+{
+    data[offset] = static_cast<uint8_t>((value >> 8U) & 0xFFU);
+    data[offset + 1U] = static_cast<uint8_t>(value & 0xFFU);
+}
+
+void writeUint32BE(std::vector<uint8_t>& data, size_t offset, uint32_t value)
+{
+    data[offset] = static_cast<uint8_t>((value >> 24U) & 0xFFU);
+    data[offset + 1U] = static_cast<uint8_t>((value >> 16U) & 0xFFU);
+    data[offset + 2U] = static_cast<uint8_t>((value >> 8U) & 0xFFU);
+    data[offset + 3U] = static_cast<uint8_t>(value & 0xFFU);
+}
+
+void writeLegacyMotorolaPeerAddresses(std::vector<uint8_t>& packet)
+{
+    if (packet.size() < 21U) {
+        return;
+    }
+
+    packet[14U] = static_cast<uint8_t>((g_motorolaArsPeerIp >> 16U) & 0xFFU);
+    packet[15U] = static_cast<uint8_t>((g_motorolaArsPeerIp >> 8U) & 0xFFU);
+    packet[16U] = static_cast<uint8_t>(g_motorolaArsPeerIp & 0xFFU);
+    packet[17U] = static_cast<uint8_t>((g_motorolaArsServerIp >> 24U) & 0xFFU);
+    packet[18U] = static_cast<uint8_t>((g_motorolaArsServerIp >> 16U) & 0xFFU);
+    packet[19U] = static_cast<uint8_t>((g_motorolaArsServerIp >> 8U) & 0xFFU);
+    packet[20U] = static_cast<uint8_t>(g_motorolaArsServerIp & 0xFFU);
+
+    std::vector<uint8_t> logicalHeader(packet.begin(), packet.begin() + 12U);
+    logicalHeader.resize(20U, 0x00U);
+    writeUint32BE(logicalHeader, 12U, g_motorolaArsPeerIp);
+    writeUint32BE(logicalHeader, 16U, g_motorolaArsServerIp);
+    writeUint16BE(logicalHeader, 10U, 0U);
+    writeUint16BE(packet, 10U, checksum16(logicalHeader.data(), logicalHeader.size()));
+}
+
+bool containsOnlyAsciiDigits(const uint8_t* data, size_t length)
+{
+    return std::all_of(data, data + length, [](uint8_t value) {
+        return value >= static_cast<uint8_t>('0') && value <= static_cast<uint8_t>('9');
+    });
+}
+
+bool parseMotorolaScepArsRegistration(const std::vector<uint8_t>& rawBlocks, uint32_t sourceRid,
+    uint32_t& subscriberIp, uint16_t& requestIpId)
+{
+    if (sourceRid == 0U || sourceRid > 9999999U) {
+        return false;
+    }
+
+    const std::string ridText = std::to_string(sourceRid);
+    if (rawBlocks.size() >= 53U && ridText.size() == 7U &&
+        rawBlocks[0U] == 0x45U && readUint16BE(rawBlocks.data() + 2U) == 53U &&
+        rawBlocks[9U] == 0x11U && readUint32BE(rawBlocks.data() + 16U) == g_motorolaArsServerIp &&
+        readUint16BE(rawBlocks.data() + 20U) == kMotorolaArsPort &&
+        readUint16BE(rawBlocks.data() + 22U) == kMotorolaArsPort &&
+        readUint16BE(rawBlocks.data() + 24U) == 33U &&
+        rawBlocks[28U] == 0x00U && rawBlocks[29U] == 0x17U &&
+        rawBlocks[30U] == 0xF0U && rawBlocks[31U] == 0x20U &&
+        rawBlocks[32U] == 0x07U && rawBlocks[40U] == 0x07U &&
+        rawBlocks[48U] == 0x04U &&
+        std::equal(ridText.begin(), ridText.end(), rawBlocks.begin() + 33U) &&
+        std::equal(ridText.begin(), ridText.end(), rawBlocks.begin() + 41U) &&
+        containsOnlyAsciiDigits(rawBlocks.data() + 49U, 4U)) {
+        subscriberIp = readUint32BE(rawBlocks.data() + 12U);
+        const uint32_t autoGeneratedIp = 0xD0000001U | ((sourceRid & 0x00FFFFFFU) << 4U);
+        if (subscriberIp != autoGeneratedIp || checksum16(rawBlocks.data(), 20U) != 0U) {
+            return false;
+        }
+
+        std::vector<uint8_t> pseudo;
+        pseudo.reserve(45U);
+        pseudo.insert(pseudo.end(), rawBlocks.begin() + 12U, rawBlocks.begin() + 20U);
+        pseudo.push_back(0x00U);
+        pseudo.push_back(0x11U);
+        pseudo.push_back(0x00U);
+        pseudo.push_back(0x21U);
+        pseudo.insert(pseudo.end(), rawBlocks.begin() + 20U, rawBlocks.begin() + 53U);
+        if (checksum16(pseudo.data(), pseudo.size()) != 0U) {
+            return false;
+        }
+
+        requestIpId = readUint16BE(rawBlocks.data() + 4U);
+        return true;
+    }
+
+    // Motorola conventional SCEP inserts transport control bytes between the
+    // logical IPv4 fragments in the legacy broken DFSI conversion. Retain this
+    // parser so an in-flight retry from the old transport can still complete.
+    if (rawBlocks.size() != 64U ||
+        rawBlocks[0U] != 0x45U || readUint16BE(rawBlocks.data() + 2U) != 53U ||
+        rawBlocks[9U] != 0x11U || readUint16BE(rawBlocks.data() + 21U) != kMotorolaArsPort ||
+        readUint16BE(rawBlocks.data() + 23U) != kMotorolaArsPort ||
+        readUint16BE(rawBlocks.data() + 25U) != 33U) {
+        return false;
+    }
+
+    subscriberIp = readUint32BE(rawBlocks.data() + 12U);
+    const uint32_t autoGeneratedIp = 0xD0000001U | ((sourceRid & 0x00FFFFFFU) << 4U);
+    if (subscriberIp != autoGeneratedIp || rawBlocks[16U] != 0x00U || rawBlocks[17U] != 0x02U ||
+        rawBlocks[18U] != static_cast<uint8_t>((g_motorolaArsServerIp >> 16U) & 0xFFU) ||
+        rawBlocks[19U] != static_cast<uint8_t>((g_motorolaArsServerIp >> 8U) & 0xFFU) ||
+        rawBlocks[20U] != static_cast<uint8_t>(g_motorolaArsServerIp & 0xFFU) ||
+        rawBlocks[29U] != 0x00U || rawBlocks[30U] != 0x17U ||
+        rawBlocks[31U] != 0xF0U || rawBlocks[32U] != 0x20U ||
+        rawBlocks[33U] != 0x00U || rawBlocks[34U] != 0x04U ||
+        rawBlocks[35U] != 0x07U || rawBlocks[42U] != 0x07U ||
+        rawBlocks[50U] != 0x00U || rawBlocks[51U] != 0x02U || rawBlocks[52U] != 0x00U ||
+        rawBlocks[53U] != 0x00U || rawBlocks[54U] != 0x06U || rawBlocks[55U] != 0x04U ||
+        !containsOnlyAsciiDigits(rawBlocks.data() + 56U, 4U)) {
+        return false;
+    }
+
+    if (ridText.size() != 7U ||
+        !std::equal(ridText.begin() + 1U, ridText.end(), rawBlocks.begin() + 36U) ||
+        !std::equal(ridText.begin(), ridText.end(), rawBlocks.begin() + 43U)) {
+        return false;
+    }
+
+    std::vector<uint8_t> packet;
+    packet.reserve(53U);
+    packet.insert(packet.end(), rawBlocks.begin(), rawBlocks.begin() + 16U);
+    packet.push_back(static_cast<uint8_t>((g_motorolaArsServerIp >> 24U) & 0xFFU));
+    packet.push_back(static_cast<uint8_t>((g_motorolaArsServerIp >> 16U) & 0xFFU));
+    packet.push_back(static_cast<uint8_t>((g_motorolaArsServerIp >> 8U) & 0xFFU));
+    packet.push_back(static_cast<uint8_t>(g_motorolaArsServerIp & 0xFFU));
+    packet.insert(packet.end(), rawBlocks.begin() + 21U, rawBlocks.begin() + 33U);
+    packet.push_back(rawBlocks[35U]);
+    packet.insert(packet.end(), ridText.begin(), ridText.end());
+    packet.push_back(rawBlocks[42U]);
+    packet.insert(packet.end(), rawBlocks.begin() + 43U, rawBlocks.begin() + 50U);
+    packet.push_back(rawBlocks[55U]);
+    packet.insert(packet.end(), rawBlocks.begin() + 56U, rawBlocks.begin() + 60U);
+
+    if (packet.size() != 53U || checksum16(packet.data(), 20U) != 0U) {
+        return false;
+    }
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + 33U);
+    pseudo.insert(pseudo.end(), packet.begin() + 12U, packet.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x21U);
+    pseudo.insert(pseudo.end(), packet.begin() + 20U, packet.end());
+    if (checksum16(pseudo.data(), pseudo.size()) != 0U) {
+        return false;
+    }
+
+    requestIpId = readUint16BE(packet.data() + 4U);
+    return true;
+}
+
+std::vector<uint8_t> buildMotorolaArsSuccess(uint32_t subscriberIp, uint16_t requestIpId)
+{
+    const uint8_t arsPayload[] = {0x00U, 0x02U, 0xBFU, 0x01U};
+    constexpr uint16_t udpLength = 12U;
+    const uint16_t packetLength = static_cast<uint16_t>(20U + udpLength);
+
+    std::vector<uint8_t> response(packetLength, 0x00U);
+    response[0U] = 0x45U;
+    writeUint16BE(response, 2U, packetLength);
+    writeUint16BE(response, 4U, static_cast<uint16_t>(requestIpId + 1U));
+    response[8U] = 0x40U;
+    response[9U] = 0x11U;
+    writeUint32BE(response, 12U, g_motorolaArsServerIp);
+    writeUint32BE(response, 16U, subscriberIp);
+    writeUint16BE(response, 20U, kMotorolaArsPort);
+    writeUint16BE(response, 22U, kMotorolaArsPort);
+    writeUint16BE(response, 24U, udpLength);
+    std::copy(arsPayload, arsPayload + sizeof(arsPayload), response.begin() + 28U);
+
+    const uint16_t ipChecksum = checksum16(response.data(), 20U);
+    writeUint16BE(response, 10U, ipChecksum);
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), response.begin() + 12U, response.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+    pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), response.begin() + 20U, response.begin() + packetLength);
+    uint16_t udpChecksum = checksum16(pseudo.data(), pseudo.size());
+    if (udpChecksum == 0U) {
+        udpChecksum = 0xFFFFU;
+    }
+    writeUint16BE(response, 26U, udpChecksum);
+    return response;
+}
+
+std::vector<uint8_t> buildMotorolaTmsServiceAvailability(uint32_t subscriberIp)
+{
+    // Advertise every server-routed target type so the subscriber does not
+    // reject a message locally before putting it on the air.
+    const uint8_t tmsPayload[] = {0x00U, 0x03U, 0xF0U, 0x00U, 0x03U};
+    const uint16_t udpLength = static_cast<uint16_t>(8U + sizeof(tmsPayload));
+    const uint16_t packetLength = static_cast<uint16_t>(20U + udpLength);
+
+    std::vector<uint8_t> response(packetLength, 0x00U);
+    response[0U] = 0x45U;
+    writeUint16BE(response, 2U, packetLength);
+    writeUint16BE(response, 4U, 0x5177U);
+    response[8U] = 0x40U;
+    response[9U] = 0x11U;
+    writeUint32BE(response, 12U, g_motorolaArsServerIp);
+    writeUint32BE(response, 16U, subscriberIp);
+    writeUint16BE(response, 20U, kMotorolaTmsPort);
+    writeUint16BE(response, 22U, kMotorolaTmsPort);
+    writeUint16BE(response, 24U, udpLength);
+    std::copy(tmsPayload, tmsPayload + sizeof(tmsPayload), response.begin() + 28U);
+
+    writeUint16BE(response, 10U, checksum16(response.data(), 20U));
+
+    std::vector<uint8_t> pseudo;
+    pseudo.reserve(12U + udpLength);
+    pseudo.insert(pseudo.end(), response.begin() + 12U, response.begin() + 20U);
+    pseudo.push_back(0x00U);
+    pseudo.push_back(0x11U);
+    pseudo.push_back(static_cast<uint8_t>((udpLength >> 8U) & 0xFFU));
+    pseudo.push_back(static_cast<uint8_t>(udpLength & 0xFFU));
+    pseudo.insert(pseudo.end(), response.begin() + 20U, response.end());
+    writeUint16BE(response, 26U, checksum16(pseudo.data(), pseudo.size()));
+    return response;
+}
