+void writeSmsInboxEvent(const std::string& application, uint32_t sourceRid, uint32_t targetRid, const std::string& text, bool broadcast, bool localDeliveryCandidate)
+{
+    static uint32_t sequence = 0U;
+    static std::unordered_map<std::string, std::chrono::steady_clock::time_point> recentEvents;
+    const auto nowSteady = std::chrono::steady_clock::now();
+    for (auto it = recentEvents.begin(); it != recentEvents.end();) {
+        if (it->second <= nowSteady) {
+            it = recentEvents.erase(it);
+        } else {
+            ++it;
+        }
+    }
+    std::ostringstream dedupeKey;
+    dedupeKey << application << '|' << sourceRid << '|' << targetRid << '|'
+              << (broadcast ? 1U : 0U) << '|' << (localDeliveryCandidate ? 1U : 0U)
+              << '|' << text;
+    const std::string key = dedupeKey.str();
+    if (recentEvents.find(key) != recentEvents.end()) {
+        LogInfoEx(LOG_RF, "Motorola SMS inbox duplicate suppressed, application = %s, sourceRid = %u, targetRid = %u",
+            application.c_str(), sourceRid, targetRid);
+        return;
+    }
+    recentEvents[key] = nowSteady + std::chrono::seconds(kSmsInboxDuplicateTtlSeconds);
+    ++sequence;
+    const auto now = std::chrono::system_clock::now();
+    const auto epochMs = std::chrono::duration_cast<std::chrono::milliseconds>(now.time_since_epoch()).count();
+    const std::string dir("/home/quantar/quantar-runtime/sms/inbox");
+    ::mkdir("/home/quantar/quantar-runtime/sms", 0775);
+    ::mkdir(dir.c_str(), 0775);
+    std::ostringstream name;
+    name << dir << "/host-" << epochMs << '-' << sequence << ".json";
+    const std::string path = name.str();
+    const std::string tempPath = path + ".tmp";
+    std::ofstream out(tempPath, std::ios::trunc);
+    if (!out.is_open()) return;
+    out << "{\n";
+    out << "  \"application\": \"" << jsonEscape(application) << "\",\n";
+    out << "  \"sourceRid\": " << sourceRid << ",\n";
+    out << "  \"targetRid\": " << targetRid << ",\n";
+    out << "  \"broadcast\": " << (broadcast ? "true" : "false") << ",\n";
+    out << "  \"localDeliveryCandidate\": " << (localDeliveryCandidate ? "true" : "false") << ",\n";
+    out << "  \"text\": \"" << jsonEscape(text) << "\"\n";
+    out << "}\n";
+    out.close();
+    ::rename(tempPath.c_str(), path.c_str());
+}
