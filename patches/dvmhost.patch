+    LogInfoEx(LOG_RF, P25_PDU_STR ", synthetic Motorola TMS delivery using peer follow-up shape, srcId = %u, dstRid = %u",
+        responderRid, sourceRid);
+    writeSyntheticMotorolaFollowup(sourceRid, responderRid);
 }
 
