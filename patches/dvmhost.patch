+bool Data::writeMotorolaTmsInboundDelivery(uint32_t targetRid, uint32_t senderRid, const std::string& text)
+{
+    const auto registration = m_fneRegTable.find(targetRid);
+    auto session = m_motorolaSessions.find(targetRid);
+    if (registration == m_fneRegTable.end() || registration->second == 0U ||
+        session == m_motorolaSessions.end() ||
+        session->second.state != MotorolaSessionState::TMS_AVAILABLE ||
+        !session->second.pendingTmsFragments.empty() ||
+        m_retryPDUData != nullptr ||
+        m_p25->m_rfState != RS_RF_LISTENING || text.empty()) {
+        return false;
+    }
+
+    const uint8_t messageId = session->second.nextTmsMessageId & 0x1FU;
+    std::vector<uint8_t> response = buildMotorolaTmsInboundMessage(
+        registration->second, messageId, std::to_string(senderRid), text);
+
+    std::vector<std::vector<uint8_t>> fragments;
+    for (size_t offset = 0U; offset < response.size(); offset += kMotorolaTmsP25FragmentBytes) {
+        const size_t length = std::min(kMotorolaTmsP25FragmentBytes, response.size() - offset);
+        fragments.emplace_back(response.begin() + offset, response.begin() + offset + length);
+    }
+    if (fragments.empty()) {
+        return false;
+    }
+
+    session->second.pendingTmsFragments = std::move(fragments);
+    session->second.pendingTmsFragmentIndex = 0U;
+    session->second.pendingTmsFragmentAck = false;
+    session->second.pendingTmsFragmentNs = 0U;
+    session->second.pendingTmsMessageId = messageId;
+    session->second.pendingTmsFragmentDelayMs = 0U;
+    session->second.pendingTmsApplicationAckMs = 0U;
+
+    LogInfoEx(LOG_RF, P25_PDU_STR ", queued Motorola TMS inbound delivery, targetRid = %u, senderRid = %u, messageId = %u, textLen = %u, packetBytes = %u, fragments = %u",
+        targetRid, senderRid, messageId, static_cast<uint32_t>(text.size()),
+        static_cast<uint32_t>(response.size()),
+        static_cast<uint32_t>(session->second.pendingTmsFragments.size()));
+
+    if (!writeNextMotorolaTmsInboundFragment(targetRid)) {
+        resetMotorolaTmsInboundDelivery(session->second);
+        return false;
+    }
+    session->second.nextTmsMessageId = static_cast<uint8_t>((messageId + 1U) & 0x1FU);
+    return true;
+}
