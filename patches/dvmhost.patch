+std::string extractMotorolaTmsText(const uint8_t* packet, uint32_t packetLength)
+{
+    if (packet == nullptr || packetLength < 32U || (packet[0U] & 0xF0U) != 0x40U || packet[9U] != 0x11U) {
+        return {};
+    }
+
+    const uint32_t ipHeaderLength = static_cast<uint32_t>(packet[0U] & 0x0FU) * 4U;
+    if (ipHeaderLength < 20U || ipHeaderLength + 8U >= packetLength) {
+        return {};
+    }
+
+    const uint8_t* payload = packet + ipHeaderLength + 8U;
+    const uint32_t payloadLength = packetLength - ipHeaderLength - 8U;
+    for (uint32_t i = 0U; i + 2U < payloadLength; ++i) {
+        if ((payload[i] & 0xE0U) != 0x80U || payload[i + 1U] != 0x04U) {
+            continue;
+        }
+
+        std::string text;
+        for (uint32_t j = i + 2U; j < payloadLength;) {
+            if (j + 1U < payloadLength && payload[j + 1U] == 0x00U &&
+                payload[j] >= 0x20U && payload[j] <= 0x7EU) {
+                text.push_back(static_cast<char>(payload[j]));
+                j += 2U;
+                continue;
+            }
+            if (payload[j] >= 0x20U && payload[j] <= 0x7EU) {
+                text.push_back(static_cast<char>(payload[j]));
+                ++j;
+                continue;
+            }
+            break;
+        }
+
+        while (!text.empty() && text.back() == ' ') {
+            text.pop_back();
+        }
+        return text;
+    }
+
+    return {};
+}
+
+uint32_t targetRidFromAutoIp(const uint8_t* packet, uint32_t packetLength, uint32_t fallbackRid)
+{
+    if (packet != nullptr && packetLength >= 20U && packet[16U] == 10U) {
+        const uint32_t rid = (static_cast<uint32_t>(packet[17U]) << 16U) |
+            (static_cast<uint32_t>(packet[18U]) << 8U) | static_cast<uint32_t>(packet[19U]);
+        if (rid != 0U) {
+            return rid;
+        }
+    }
+
+    if (fallbackRid != WUID_FNE && fallbackRid != WUID_ALL) {
+        return fallbackRid;
+    }
+    return 0U;
+}
+
+bool writeMotorolaTmsEvent(const uint8_t* packet, uint32_t packetLength, uint32_t sourceRid, uint32_t fallbackTargetRid)
+{
+    const std::string text = extractMotorolaTmsText(packet, packetLength);
+    const uint32_t targetRid = targetRidFromAutoIp(packet, packetLength, fallbackTargetRid);
+    if (text.empty() || sourceRid == 0U || targetRid == 0U) {
+        return false;
+    }
+
+    static uint32_t sequence = 0U;
+    static std::unordered_map<std::string, std::chrono::steady_clock::time_point> recentEvents;
+    const auto nowSteady = std::chrono::steady_clock::now();
+    for (auto it = recentEvents.begin(); it != recentEvents.end();) {
+        if (it->second <= nowSteady) {
+            it = recentEvents.erase(it);
+        } else {
+            ++it;
+        }
+    }
+
+    std::ostringstream keyStream;
+    keyStream << sourceRid << '|' << targetRid << '|' << text;
+    const std::string key = keyStream.str();
+    if (recentEvents.find(key) != recentEvents.end()) {
+        LogInfoEx(LOG_P25, "Motorola FNE TMS duplicate suppressed, sourceRid = %u, targetRid = %u", sourceRid, targetRid);
+        return true;
+    }
+    recentEvents[key] = nowSteady + std::chrono::seconds(TMS_EVENT_TTL_SECONDS);
+
+    ::mkdir("/home/quantar/quantar-runtime/sms", 0775);
+    ::mkdir(TMS_INBOX_PATH, 0775);
+    const auto now = std::chrono::system_clock::now();
+    const auto epochMs = std::chrono::duration_cast<std::chrono::milliseconds>(now.time_since_epoch()).count();
+    std::ostringstream pathStream;
+    pathStream << TMS_INBOX_PATH << "/fne-" << epochMs << '-' << ++sequence << ".json";
+    const std::string path = pathStream.str();
+    const std::string tempPath = path + ".tmp";
+
+    std::ofstream output(tempPath, std::ios::trunc);
+    if (!output.is_open()) {
+        LogError(LOG_P25, "Motorola FNE TMS failed to open inbox event, path = %s", tempPath.c_str());
+        return false;
+    }
+    output << "{\n  \"application\": \"motorola_tms\",\n";
+    output << "  \"sourceRid\": " << sourceRid << ",\n";
+    output << "  \"targetRid\": " << targetRid << ",\n";
+    output << "  \"broadcast\": false,\n  \"localDeliveryCandidate\": false,\n  \"text\": \"";
+    for (const char c : text) {
+        if (c == '\\' || c == '"') {
+            output << '\\';
+        }
+        output << c;
+    }
+    output << "\"\n}\n";
+    output.close();
+    if (!output || ::rename(tempPath.c_str(), path.c_str()) != 0) {
+        LogError(LOG_P25, "Motorola FNE TMS failed to commit inbox event, path = %s", path.c_str());
+        return false;
+    }
+
+    LogInfoEx(LOG_P25, "Motorola FNE TMS queued, sourceRid = %u, targetRid = %u, textLength = %u",
+        sourceRid, targetRid, static_cast<uint32_t>(text.size()));
+    return true;
+}
