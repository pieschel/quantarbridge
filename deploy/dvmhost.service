[Unit]
Description=DVM Host for Quantar DFSI
After=network-online.target dvmfne.service
Wants=network-online.target

[Service]
Type=simple
User=quantar
WorkingDirectory=/home/quantar/quantar-runtime
ExecStart=/home/quantar/src/dvmhost/build/dvmhost -c /home/quantar/quantar-runtime/dvmhost-config.yml
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
